<Application x:Class="CubicAIExplorer.App"
             xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
             xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
             xmlns:converters="clr-namespace:CubicAIExplorer.Converters">
    <Application.Resources>
        <SolidColorBrush x:Key="ClassicChromeBorderBrush" Color="#6B8BB6" />
        <SolidColorBrush x:Key="ClassicPaneBorderBrush" Color="#9FB7D6" />
        <SolidColorBrush x:Key="ClassicPaneBackgroundBrush" Color="#F3F7FC" />
        <SolidColorBrush x:Key="ClassicTextBrush" Color="#1E2A3A" />

        <LinearGradientBrush x:Key="ClassicWindowBrush" StartPoint="0,0" EndPoint="0,1">
            <GradientStop Color="#EAF2FD" Offset="0" />
            <GradientStop Color="#D5E4F7" Offset="1" />
        </LinearGradientBrush>

        <LinearGradientBrush x:Key="ClassicChromeBrush" StartPoint="0,0" EndPoint="0,1">
            <GradientStop Color="#F7FBFF" Offset="0" />
            <GradientStop Color="#D6E7FB" Offset="1" />
        </LinearGradientBrush>

        <LinearGradientBrush x:Key="ClassicHeaderBrush" StartPoint="0,0" EndPoint="0,1">
            <GradientStop Color="#EAF4FF" Offset="0" />
            <GradientStop Color="#C8DCF6" Offset="1" />
        </LinearGradientBrush>

        <Style TargetType="Window">
            <Setter Property="FontFamily" Value="Tahoma" />
            <Setter Property="FontSize" Value="12" />
            <Setter Property="Foreground" Value="{StaticResource ClassicTextBrush}" />
            <Setter Property="Background" Value="{StaticResource ClassicWindowBrush}" />
        </Style>

        <Style TargetType="Menu">
            <Setter Property="Background" Value="{StaticResource ClassicChromeBrush}" />
            <Setter Property="BorderBrush" Value="{StaticResource ClassicChromeBorderBrush}" />
            <Setter Property="BorderThickness" Value="0,0,0,1" />
        </Style>

        <Style TargetType="ToolBarTray">
            <Setter Property="Background" Value="{StaticResource ClassicChromeBrush}" />
        </Style>

        <Style TargetType="ToolBar">
            <Setter Property="Background" Value="{StaticResource ClassicChromeBrush}" />
            <Setter Property="BorderBrush" Value="{StaticResource ClassicChromeBorderBrush}" />
            <Setter Property="BorderThickness" Value="1" />
        </Style>

        <Style TargetType="StatusBar">
            <Setter Property="Background" Value="{StaticResource ClassicChromeBrush}" />
            <Setter Property="BorderBrush" Value="{StaticResource ClassicChromeBorderBrush}" />
            <Setter Property="BorderThickness" Value="1,1,1,0" />
        </Style>

        <Style TargetType="TabControl">
            <Setter Property="Background" Value="#D7E8FC" />
            <Setter Property="BorderBrush" Value="{StaticResource ClassicChromeBorderBrush}" />
            <Setter Property="BorderThickness" Value="0,1,0,1" />
        </Style>

        <Style x:Key="ClassicPaneHeaderTextStyle" TargetType="TextBlock">
            <Setter Property="FontWeight" Value="SemiBold" />
            <Setter Property="Padding" Value="8,4" />
            <Setter Property="Background" Value="{StaticResource ClassicHeaderBrush}" />
        </Style>

        <Style x:Key="ClassicPaneSurfaceStyle" TargetType="Border">
            <Setter Property="Background" Value="{StaticResource ClassicPaneBackgroundBrush}" />
            <Setter Property="BorderBrush" Value="{StaticResource ClassicPaneBorderBrush}" />
            <Setter Property="BorderThickness" Value="1" />
        </Style>

        <converters:FileSizeConverter x:Key="FileSizeConverter" />
        <converters:ShellIconConverter x:Key="ShellIconConverter" />
        <BooleanToVisibilityConverter x:Key="BoolToVisibility" />

        <!-- Toolbar Icon Resources (vector, resolution-independent) -->
        <DrawingImage x:Key="IconBack">
            <DrawingImage.Drawing>
                <GeometryDrawing Brush="#3366AA" Geometry="M 12,2 L 4,8 L 12,14 L 12,10 L 15,10 L 15,6 L 12,6 Z" />
            </DrawingImage.Drawing>
        </DrawingImage>
        <DrawingImage x:Key="IconForward">
            <DrawingImage.Drawing>
                <GeometryDrawing Brush="#3366AA" Geometry="M 4,2 L 12,8 L 4,14 L 4,10 L 1,10 L 1,6 L 4,6 Z" />
            </DrawingImage.Drawing>
        </DrawingImage>
        <DrawingImage x:Key="IconUp">
            <DrawingImage.Drawing>
                <GeometryDrawing Brush="#3366AA" Geometry="M 2,12 L 8,4 L 14,12 L 10,12 L 10,15 L 6,15 L 6,12 Z" />
            </DrawingImage.Drawing>
        </DrawingImage>
        <DrawingImage x:Key="IconCut">
            <DrawingImage.Drawing>
                <DrawingGroup>
                    <GeometryDrawing Brush="#CC4444" Geometry="M 5,0 L 8,6 L 11,0 L 9.5,0 L 8,3 L 6.5,0 Z" />
                    <GeometryDrawing Brush="#CC4444" Pen="{x:Null}">
                        <GeometryDrawing.Geometry>
                            <EllipseGeometry Center="5,10" RadiusX="3" RadiusY="3" />
                        </GeometryDrawing.Geometry>
                    </GeometryDrawing>
                    <GeometryDrawing Brush="#FFFFFF">
                        <GeometryDrawing.Geometry>
                            <EllipseGeometry Center="5,10" RadiusX="1.5" RadiusY="1.5" />
                        </GeometryDrawing.Geometry>
                    </GeometryDrawing>
                    <GeometryDrawing Brush="#CC4444" Pen="{x:Null}">
                        <GeometryDrawing.Geometry>
                            <EllipseGeometry Center="11,10" RadiusX="3" RadiusY="3" />
                        </GeometryDrawing.Geometry>
                    </GeometryDrawing>
                    <GeometryDrawing Brush="#FFFFFF">
                        <GeometryDrawing.Geometry>
                            <EllipseGeometry Center="11,10" RadiusX="1.5" RadiusY="1.5" />
                        </GeometryDrawing.Geometry>
                    </GeometryDrawing>
                </DrawingGroup>
            </DrawingImage.Drawing>
        </DrawingImage>
        <DrawingImage x:Key="IconCopy">
            <DrawingImage.Drawing>
                <DrawingGroup>
                    <GeometryDrawing Brush="#EEEECC" Geometry="M 3,3 L 3,15 L 11,15 L 11,3 Z">
                        <GeometryDrawing.Pen>
                            <Pen Brush="#886622" Thickness="1" />
                        </GeometryDrawing.Pen>
                    </GeometryDrawing>
                    <GeometryDrawing Brush="#FEFFDD" Geometry="M 5,1 L 5,12 L 13,12 L 13,1 Z">
                        <GeometryDrawing.Pen>
                            <Pen Brush="#886622" Thickness="1" />
                        </GeometryDrawing.Pen>
                    </GeometryDrawing>
                </DrawingGroup>
            </DrawingImage.Drawing>
        </DrawingImage>
        <DrawingImage x:Key="IconPaste">
            <DrawingImage.Drawing>
                <DrawingGroup>
                    <GeometryDrawing Brush="#CC9933" Geometry="M 1,4 L 1,15 L 10,15 L 10,4 Z">
                        <GeometryDrawing.Pen>
                            <Pen Brush="#886622" Thickness="1" />
                        </GeometryDrawing.Pen>
                    </GeometryDrawing>
                    <GeometryDrawing Brush="#FEFFDD" Geometry="M 4,1 L 4,12 L 14,12 L 14,1 Z">
                        <GeometryDrawing.Pen>
                            <Pen Brush="#886622" Thickness="1" />
                        </GeometryDrawing.Pen>
                    </GeometryDrawing>
                    <GeometryDrawing Brush="#AAAAAA" Geometry="M 6,2 L 6,4 L 12,4 L 12,2 Z" />
                </DrawingGroup>
            </DrawingImage.Drawing>
        </DrawingImage>
        <DrawingImage x:Key="IconDelete">
            <DrawingImage.Drawing>
                <DrawingGroup>
                    <GeometryDrawing Brush="#DD3333" Geometry="M 3,2 L 2,3 L 6,8 L 2,13 L 3,14 L 8,10 L 13,14 L 14,13 L 10,8 L 14,3 L 13,2 L 8,6 Z" />
                </DrawingGroup>
            </DrawingImage.Drawing>
        </DrawingImage>
        <DrawingImage x:Key="IconUndo">
            <DrawingImage.Drawing>
                <DrawingGroup>
                    <GeometryDrawing Brush="#3366AA" Geometry="M 2,7 L 7,3 L 7,5.5 C 10,5 13,6 14,10 C 12,7 10,7 7,7.5 L 7,10 Z" />
                </DrawingGroup>
            </DrawingImage.Drawing>
        </DrawingImage>
        <DrawingImage x:Key="IconRedo">
            <DrawingImage.Drawing>
                <DrawingGroup>
                    <GeometryDrawing Brush="#3366AA" Geometry="M 14,7 L 9,3 L 9,5.5 C 6,5 3,6 2,10 C 4,7 6,7 9,7.5 L 9,10 Z" />
                </DrawingGroup>
            </DrawingImage.Drawing>
        </DrawingImage>
        <DrawingImage x:Key="IconGo">
            <DrawingImage.Drawing>
                <GeometryDrawing Brush="#339933" Geometry="M 3,2 L 13,8 L 3,14 Z" />
            </DrawingImage.Drawing>
        </DrawingImage>
        <DrawingImage x:Key="IconRefresh">
            <DrawingImage.Drawing>
                <DrawingGroup>
                    <GeometryDrawing Brush="#339933" Geometry="M 8,2 C 4,2 1,5 1,8 C 1,11 4,14 8,14 C 12,14 15,11 15,8 L 12,8 C 12,10 10,12 8,12 C 6,12 4,10 4,8 C 4,6 6,4 8,4 L 8,7 L 12,3.5 L 8,0 Z" />
                </DrawingGroup>
            </DrawingImage.Drawing>
        </DrawingImage>
        <DrawingImage x:Key="IconSearch">
            <DrawingImage.Drawing>
                <DrawingGroup>
                    <GeometryDrawing Brush="#6699CC">
                        <GeometryDrawing.Geometry>
                            <EllipseGeometry Center="6.5,6.5" RadiusX="5" RadiusY="5" />
                        </GeometryDrawing.Geometry>
                    </GeometryDrawing>
                    <GeometryDrawing Brush="#EAF2FD">
                        <GeometryDrawing.Geometry>
                            <EllipseGeometry Center="6.5,6.5" RadiusX="3" RadiusY="3" />
                        </GeometryDrawing.Geometry>
                    </GeometryDrawing>
                    <GeometryDrawing Brush="#886622" Geometry="M 10,10 L 15,15 L 14,16 L 9,11 Z" />
                </DrawingGroup>
            </DrawingImage.Drawing>
        </DrawingImage>
        <DrawingImage x:Key="IconFolder">
            <DrawingImage.Drawing>
                <DrawingGroup>
                    <GeometryDrawing Brush="#FFCC44" Geometry="M 1,4 L 1,14 L 15,14 L 15,5 L 7,5 L 6,3 L 1,3 Z">
                        <GeometryDrawing.Pen>
                            <Pen Brush="#CC9922" Thickness="0.5" />
                        </GeometryDrawing.Pen>
                    </GeometryDrawing>
                </DrawingGroup>
            </DrawingImage.Drawing>
        </DrawingImage>
        <DrawingImage x:Key="IconClock">
            <DrawingImage.Drawing>
                <DrawingGroup>
                    <GeometryDrawing Brush="#EEEEFF">
                        <GeometryDrawing.Geometry>
                            <EllipseGeometry Center="8,8" RadiusX="7" RadiusY="7" />
                        </GeometryDrawing.Geometry>
                        <GeometryDrawing.Pen>
                            <Pen Brush="#3366AA" Thickness="1" />
                        </GeometryDrawing.Pen>
                    </GeometryDrawing>
                    <GeometryDrawing Geometry="M 8,3 L 8,8 L 12,8">
                        <GeometryDrawing.Pen>
                            <Pen Brush="#3366AA" Thickness="1.2" />
                        </GeometryDrawing.Pen>
                    </GeometryDrawing>
                </DrawingGroup>
            </DrawingImage.Drawing>
        </DrawingImage>

        <!-- Details view: Name column cell template -->
        <DataTemplate x:Key="DetailsNameCellTemplate">
            <StackPanel Orientation="Horizontal">
                <Image Source="{Binding ., Converter={StaticResource ShellIconConverter}}"
                       Width="16" Height="16" Margin="0,0,6,0" />
                <TextBlock x:Name="FileNameTextBlock" Text="{Binding Name}" />
            </StackPanel>
        </DataTemplate>

        <!-- List view: compact single-line items -->
        <DataTemplate x:Key="ListViewItemTemplate">
            <StackPanel Orientation="Horizontal" Margin="2,1">
                <Image Source="{Binding ., Converter={StaticResource ShellIconConverter}}"
                       Width="16" Height="16" Margin="0,0,4,0" />
                <TextBlock Text="{Binding Name}" VerticalAlignment="Center" />
            </StackPanel>
        </DataTemplate>

        <!-- Tile view: icon + name + type side by side -->
        <DataTemplate x:Key="TileViewItemTemplate">
            <StackPanel Orientation="Horizontal" Margin="4,3" Width="220">
                <Image Source="{Binding ., Converter={StaticResource ShellIconConverter}}"
                       Width="32" Height="32" Margin="0,0,6,0"
                       RenderOptions.BitmapScalingMode="HighQuality" />
                <StackPanel VerticalAlignment="Center">
                    <TextBlock Text="{Binding Name}" TextTrimming="CharacterEllipsis"
                               FontWeight="SemiBold" MaxWidth="170" />
                    <TextBlock Text="{Binding TypeDescription}" Foreground="Gray"
                               FontSize="10" />
                </StackPanel>
            </StackPanel>
        </DataTemplate>

        <!-- WrapPanel for tile/list non-details views -->
        <ItemsPanelTemplate x:Key="TileItemsPanelTemplate">
            <WrapPanel Orientation="Horizontal" />
        </ItemsPanelTemplate>
    </Application.Resources>
</Application>
