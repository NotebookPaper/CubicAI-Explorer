<Window x:Class="CubicAIExplorer.MainWindow"
        xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
        xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
        xmlns:vm="clr-namespace:CubicAIExplorer.ViewModels"
        xmlns:models="clr-namespace:CubicAIExplorer.Models"
        Title="CubicAI Explorer" Height="700" Width="1100"
        WindowStartupLocation="CenterScreen"
        d:DataContext="{d:DesignInstance vm:MainViewModel}"
        xmlns:d="http://schemas.microsoft.com/expression/blend/2008"
        xmlns:mc="http://schemas.openxmlformats.org/markup-compatibility/2006"
        mc:Ignorable="d">

    <Window.InputBindings>
        <KeyBinding Key="T" Modifiers="Ctrl" Command="{Binding NewTabCommand}" />
        <KeyBinding Key="W" Modifiers="Ctrl" Command="{Binding CloseTabCommand}" CommandParameter="{Binding ActiveTab}" />
        <KeyBinding Key="L" Modifiers="Ctrl" Command="{Binding NavigateToAddressCommand}" />
        <KeyBinding Key="D" Modifiers="Ctrl" Command="{Binding AddBookmarkCommand}" />
        <KeyBinding Key="Z" Modifiers="Ctrl" Command="{Binding UndoCommand}" />
        <KeyBinding Key="Y" Modifiers="Ctrl" Command="{Binding RedoCommand}" />
        <KeyBinding Key="Z" Modifiers="Ctrl+Shift" Command="{Binding RedoCommand}" />
        <KeyBinding Key="C" Modifiers="Ctrl" Command="{Binding CopyCommand}" />
        <KeyBinding Key="X" Modifiers="Ctrl" Command="{Binding CutCommand}" />
        <KeyBinding Key="V" Modifiers="Ctrl" Command="{Binding PasteCommand}" />
        <KeyBinding Key="Delete" Command="{Binding DeleteCommand}" />
        <KeyBinding Key="Delete" Modifiers="Shift" Command="{Binding PermanentDeleteCommand}" />
        <KeyBinding Key="F2" Command="{Binding RenameCommand}" />
        <KeyBinding Key="F5" Command="{Binding RefreshCommand}" />
        <KeyBinding Key="N" Modifiers="Ctrl+Shift" Command="{Binding NewFolderCommand}" />
        <KeyBinding Key="A" Modifiers="Ctrl" Command="{Binding SelectAllCommand}" />
        <KeyBinding Key="BrowserBack" Command="{Binding GoBackCommand}" />
        <KeyBinding Key="BrowserForward" Command="{Binding GoForwardCommand}" />
        <KeyBinding Key="Back" Command="{Binding NavigateUpCommand}" />
        <KeyBinding Key="Return" Modifiers="Alt" Command="{Binding ShowPropertiesCommand}" />
        <KeyBinding Key="E" Modifiers="Ctrl" Command="{Binding SearchInFolderCommand}" />
        <KeyBinding Key="F6" Command="{Binding ToggleDualPaneCommand}" />
        <KeyBinding Key="F7" Command="{Binding TogglePreviewCommand}" />
    </Window.InputBindings>

    <DockPanel>
        <!-- Menu Bar -->
        <Menu DockPanel.Dock="Top">
            <MenuItem Header="_File">
                <MenuItem Header="_New Tab" InputGestureText="Ctrl+T" Command="{Binding NewTabCommand}" />
                <MenuItem Header="_Close Tab" InputGestureText="Ctrl+W" Command="{Binding CloseTabCommand}" CommandParameter="{Binding ActiveTab}" />
                <Separator />
                <MenuItem Header="E_xit" InputGestureText="Alt+F4" Click="OnExitClick" />
            </MenuItem>
            <MenuItem Header="_Edit">
                <MenuItem Header="{Binding ActiveUndoDescription}" InputGestureText="Ctrl+Z" Command="{Binding UndoCommand}" />
                <MenuItem Header="{Binding ActiveRedoDescription}" InputGestureText="Ctrl+Y" Command="{Binding RedoCommand}" />
                <Separator />
                <MenuItem Header="Clear History" Command="{Binding ClearHistoryCommand}" />
            </MenuItem>
            <MenuItem Header="_View">
                <MenuItem Header="_Details" Click="ViewMode_Details_Click" />
                <MenuItem Header="_List" Click="ViewMode_List_Click" />
                <MenuItem Header="_Tiles" Click="ViewMode_Tiles_Click" />
                <Separator />
                <MenuItem Header="_Toolbars">
                    <MenuItem Header="_Toolbar" IsCheckable="True" IsChecked="{Binding IsToolbarVisible}" />
                    <MenuItem Header="_Address Bar" IsCheckable="True" IsChecked="{Binding IsAddressBarVisible}" />
                    <MenuItem Header="_Status Bar" IsCheckable="True" IsChecked="{Binding IsStatusBarVisible}" />
                    <Separator />
                    <MenuItem Header="_Drives" IsCheckable="True" IsChecked="{Binding IsDrivesVisible}" />
                    <MenuItem Header="_Tabs" IsCheckable="True" IsChecked="{Binding IsTabsVisible}" />
                    <Separator />
                    <MenuItem Header="_Recent Folders" IsCheckable="True" IsChecked="{Binding IsRecentFoldersVisible}" />
                    <MenuItem Header="_Bookmarks" IsCheckable="True" IsChecked="{Binding IsBookmarksVisible}" />
                    <MenuItem Header="_Saved Searches" IsCheckable="True" IsChecked="{Binding IsSavedSearchesVisible}" />
                </MenuItem>
                <Separator />
                <MenuItem Header="_Search in Folder..." InputGestureText="Ctrl+E"
                          Command="{Binding SearchInFolderCommand}" />
                <Separator />
                <MenuItem Header="Dual _Pane" InputGestureText="F6" IsCheckable="True"
                          IsChecked="{Binding IsDualPaneMode}"
                          Command="{Binding ToggleDualPaneCommand}" />
                <MenuItem Header="_Preview Panel" InputGestureText="F7" IsCheckable="True"
                          IsChecked="{Binding IsPreviewVisible}"
                          Command="{Binding TogglePreviewCommand}" />
                <Separator />
                <MenuItem Header="Show _Hidden Files" IsCheckable="True"
                          IsChecked="{Binding CurrentPaneFileList.ShowHiddenFiles}" />
            </MenuItem>
            <MenuItem Header="_Tools">
                <MenuItem Header="_Preferences..." Command="{Binding OpenPreferencesCommand}" />
            </MenuItem>
            <MenuItem Header="_Help">
                <MenuItem Header="_About CubicAI Explorer" Click="OnAboutClick" />
            </MenuItem>
        </Menu>

        <!-- Toolbar -->
        <ToolBarTray DockPanel.Dock="Top" IsLocked="True" Visibility="{Binding IsToolbarVisible, Converter={StaticResource BoolToVisibility}}">
            <ToolBar Band="0" BandIndex="0">
                <!-- Navigation -->
                <Button Command="{Binding GoBackCommand}" ToolTip="Back (Alt+Left)" Padding="4,2" MinWidth="26">
                    <Image Source="{StaticResource IconBack}" Width="16" Height="16" />
                </Button>
                <Button Command="{Binding GoForwardCommand}" ToolTip="Forward (Alt+Right)" Padding="4,2" MinWidth="26">
                    <Image Source="{StaticResource IconForward}" Width="16" Height="16" />
                </Button>
                <Button Command="{Binding NavigateUpCommand}" ToolTip="Up (Backspace)" Padding="4,2" MinWidth="26">
                    <Image Source="{StaticResource IconUp}" Width="16" Height="16" />
                </Button>
                <Separator />
                <!-- File Operations -->
                <Button Command="{Binding CutCommand}" ToolTip="Cut (Ctrl+X)" Padding="4,2" MinWidth="26">
                    <Image Source="{StaticResource IconCut}" Width="16" Height="16" />
                </Button>
                <Button Command="{Binding CopyCommand}" ToolTip="Copy (Ctrl+C)" Padding="4,2" MinWidth="26">
                    <Image Source="{StaticResource IconCopy}" Width="16" Height="16" />
                </Button>
                <Button Command="{Binding PasteCommand}" ToolTip="Paste (Ctrl+V)" Padding="4,2" MinWidth="26">
                    <Image Source="{StaticResource IconPaste}" Width="16" Height="16" />
                </Button>
                <Separator />
                <Button Command="{Binding DeleteCommand}" ToolTip="Delete (Del)" Padding="4,2" MinWidth="26">
                    <Image Source="{StaticResource IconDelete}" Width="16" Height="16" />
                </Button>
                <Separator />
                <Button Command="{Binding UndoCommand}" ToolTip="{Binding ActiveUndoDescription}" Padding="4,2" MinWidth="26">
                    <Image Source="{StaticResource IconUndo}" Width="16" Height="16" />
                </Button>
                <Button Command="{Binding RedoCommand}" ToolTip="{Binding ActiveRedoDescription}" Padding="4,2" MinWidth="26">
                    <Image Source="{StaticResource IconRedo}" Width="16" Height="16" />
                </Button>
                <Separator />
                <Button Command="{Binding RefreshCommand}" ToolTip="Refresh (F5)" Padding="4,2" MinWidth="26">
                    <Image Source="{StaticResource IconRefresh}" Width="16" Height="16" />
                </Button>
            </ToolBar>
        </ToolBarTray>

        <!-- Address / Breadcrumb Bar -->
        <Border DockPanel.Dock="Top" Background="{StaticResource ClassicChromeBrush}"
                BorderBrush="{StaticResource ClassicChromeBorderBrush}" BorderThickness="0,0,0,1"
                Padding="4,2" Visibility="{Binding IsAddressBarVisible, Converter={StaticResource BoolToVisibility}}">
            <Grid>
                <!-- Breadcrumb mode -->
                <DockPanel x:Name="BreadcrumbBar" Visibility="Visible"
                           MouseLeftButtonDown="BreadcrumbBar_MouseDown">
                    <Button DockPanel.Dock="Right" Command="{Binding NavigateToAddressCommand}"
                            ToolTip="Go" Padding="4,2" MinWidth="24" Margin="2,0,0,0">
                        <Image Source="{StaticResource IconGo}" Width="14" Height="14" />
                    </Button>
                    <ItemsControl x:Name="BreadcrumbItems" ItemsSource="{Binding BreadcrumbSegments}"
                                  VerticalAlignment="Center">
                        <ItemsControl.ItemsPanel>
                            <ItemsPanelTemplate>
                                <StackPanel Orientation="Horizontal" />
                            </ItemsPanelTemplate>
                        </ItemsControl.ItemsPanel>
                        <ItemsControl.ItemTemplate>
                            <DataTemplate>
                                <StackPanel Orientation="Horizontal">
                                    <TextBlock Text="\" Foreground="#999999" VerticalAlignment="Center"
                                               Margin="0,0,0,0" FontSize="11"
                                               Visibility="{Binding SeparatorVisibility}" />
                                    <Button Content="{Binding DisplayName}" Tag="{Binding FullPath}"
                                            Click="BreadcrumbSegment_Click"
                                            Background="Transparent" BorderThickness="0"
                                            Padding="3,1" Cursor="Hand"
                                            FontSize="12">
                                        <Button.Style>
                                            <Style TargetType="Button">
                                                <Style.Triggers>
                                                    <Trigger Property="IsMouseOver" Value="True">
                                                        <Setter Property="Foreground" Value="#2255AA" />
                                                        <Setter Property="Background" Value="#E0EEFF" />
                                                    </Trigger>
                                                </Style.Triggers>
                                            </Style>
                                        </Button.Style>
                                    </Button>
                                </StackPanel>
                            </DataTemplate>
                        </ItemsControl.ItemTemplate>
                    </ItemsControl>
                </DockPanel>

                <!-- Edit mode (TextBox) -->
                <DockPanel x:Name="AddressBarPanel" Visibility="Collapsed">
                    <Button DockPanel.Dock="Right" Command="{Binding NavigateToAddressCommand}"
                            ToolTip="Go" Padding="4,2" MinWidth="24" Margin="2,0,0,0"
                            Click="AddressBarGo_Click">
                        <Image Source="{StaticResource IconGo}" Width="14" Height="14" />
                    </Button>
                    <Grid>
                        <TextBox x:Name="AddressBar"
                                 Text="{Binding AddressBarText, UpdateSourceTrigger=PropertyChanged}"
                                 KeyDown="AddressBar_KeyDown"
                                 LostKeyboardFocus="AddressBar_LostFocus"
                                 TextChanged="AddressBar_TextChanged"
                                 VerticalContentAlignment="Center" Padding="4,2"
                                 TabIndex="10" />
                        <Popup x:Name="AddressAutoCompletePopup"
                               PlacementTarget="{Binding ElementName=AddressBar}"
                               Placement="Bottom"
                               StaysOpen="False"
                               AllowsTransparency="True"
                               Width="{Binding ActualWidth, ElementName=AddressBar}">
                            <Border BorderBrush="#999999" BorderThickness="1" Background="White"
                                    MaxHeight="250">
                                <ListBox x:Name="AutoCompleteList"
                                         ItemsSource="{Binding AddressSuggestions}"
                                         MaxHeight="240"
                                         PreviewMouseLeftButtonUp="AutoComplete_Select" />
                            </Border>
                        </Popup>
                    </Grid>
                </DockPanel>
            </Grid>
        </Border>

        <!-- Tab Bar -->
        <DockPanel DockPanel.Dock="Top" Background="{StaticResource ClassicChromeBrush}" Visibility="{Binding IsTabsVisible, Converter={StaticResource BoolToVisibility}}">
            <Button DockPanel.Dock="Right" Command="{Binding NewTabCommand}"
                    Content="+" FontSize="14" Padding="8,2" Margin="2"
                    ToolTip="New Tab (Ctrl+T)" />
            <TabControl ItemsSource="{Binding Tabs}" SelectedItem="{Binding ActiveTab}"
                        Padding="0" Margin="0">
                <TabControl.ItemTemplate>
                    <DataTemplate DataType="{x:Type vm:TabViewModel}">
                        <DockPanel MinWidth="80" MaxWidth="200">
                            <DockPanel.ContextMenu>
                                <ContextMenu>
                                    <MenuItem Header="Duplicate Tab" Click="DuplicateTab_Click"
                                              Tag="{Binding}" />
                                    <Separator />
                                    <MenuItem Header="Close Tab" Click="CloseTab_Click"
                                              Tag="{Binding}" />
                                    <MenuItem Header="Close Other Tabs" Click="CloseOtherTabs_Click"
                                              Tag="{Binding}" />
                                </ContextMenu>
                            </DockPanel.ContextMenu>
                            <Button DockPanel.Dock="Right" Content="x" FontSize="10"
                                    Padding="4,0" Margin="4,0,0,0" BorderThickness="0"
                                    Background="Transparent"
                                    Command="{Binding DataContext.CloseTabCommand, RelativeSource={RelativeSource AncestorType=Window}}"
                                    CommandParameter="{Binding}" ToolTip="Close Tab" />
                            <TextBlock Text="{Binding Title}" TextTrimming="CharacterEllipsis"
                                       VerticalAlignment="Center" Margin="4,2" />
                        </DockPanel>
                    </DataTemplate>
                </TabControl.ItemTemplate>
                <TabControl.ContentTemplate>
                    <DataTemplate DataType="{x:Type vm:TabViewModel}">
                        <!-- Empty - we display content below the tab strip -->
                        <Border />
                    </DataTemplate>
                </TabControl.ContentTemplate>
            </TabControl>
        </DockPanel>

        <Border DockPanel.Dock="Bottom"
                Background="#EEF4FC"
                BorderBrush="{StaticResource ClassicChromeBorderBrush}"
                BorderThickness="0,1,0,0"
                Padding="8,6"
                Visibility="{Binding IsQueueDetailsVisible, Converter={StaticResource BoolToVisibility}}">
            <Grid>
                <Grid.RowDefinitions>
                    <RowDefinition Height="Auto" />
                    <RowDefinition Height="Auto" />
                </Grid.RowDefinitions>
                <DockPanel Grid.Row="0" Margin="0,0,0,6">
                    <Button DockPanel.Dock="Right"
                            Content="Cancel"
                            Padding="8,2"
                            Margin="0,0,8,0"
                            Command="{Binding CancelFileOperationQueueCommand}"
                            Visibility="{Binding CanCancelFileOperationQueue, Converter={StaticResource BoolToVisibility}}" />
                    <Button DockPanel.Dock="Right"
                            Content="Hide"
                            Padding="8,2"
                            Command="{Binding ToggleQueueDetailsCommand}" />
                    <TextBlock FontWeight="SemiBold" VerticalAlignment="Center" Text="Background File Queue" />
                </DockPanel>
                <Grid Grid.Row="1">
                    <Grid.RowDefinitions>
                        <RowDefinition Height="Auto" />
                        <RowDefinition Height="Auto" />
                    </Grid.RowDefinitions>
                    <Grid Grid.Row="0">
                        <Grid.ColumnDefinitions>
                            <ColumnDefinition Width="2*" />
                            <ColumnDefinition Width="Auto" />
                            <ColumnDefinition Width="2*" />
                            <ColumnDefinition Width="Auto" />
                            <ColumnDefinition Width="3*" />
                        </Grid.ColumnDefinitions>
                        <StackPanel Grid.Column="0">
                            <TextBlock Text="Current" FontWeight="SemiBold" />
                            <TextBlock Text="{Binding FileOperationQueueCurrentOperationText, Mode=OneWay, TargetNullValue=Idle}" />
                            <TextBlock Text="{Binding FileOperationQueueCurrentOperationDetailText, Mode=OneWay}"
                                       Foreground="#5A6F89"
                                       TextWrapping="Wrap"
                                       Visibility="{Binding CanCancelFileOperationQueue, Converter={StaticResource BoolToVisibility}}" />
                        </StackPanel>
                        <Separator Grid.Column="1" Margin="10,0" />
                        <StackPanel Grid.Column="2">
                            <TextBlock Text="Pending" FontWeight="SemiBold" />
                            <TextBlock Text="{Binding FileOperationQueuePendingCount, Mode=OneWay}" />
                            <TextBlock Text="{Binding FileOperationQueueCurrentOperationProgressText, Mode=OneWay}" />
                        </StackPanel>
                        <Separator Grid.Column="3" Margin="10,0" />
                        <StackPanel Grid.Column="4">
                            <TextBlock Text="Last Result" FontWeight="SemiBold" />
                            <TextBlock Text="{Binding FileOperationQueueLastCompletedStatusText, Mode=OneWay}" TextWrapping="Wrap" />
                        </StackPanel>
                    </Grid>
                    <StackPanel Grid.Row="1" Margin="0,8,0,0">
                        <TextBlock Text="Progress" FontWeight="SemiBold"
                                   Visibility="{Binding CanCancelFileOperationQueue, Converter={StaticResource BoolToVisibility}}" />
                        <ProgressBar Height="14"
                                     Minimum="0"
                                     Maximum="1"
                                     Value="{Binding FileOperationQueueCurrentOperationProgressFraction, Mode=OneWay}"
                                     Visibility="{Binding CanCancelFileOperationQueue, Converter={StaticResource BoolToVisibility}}" />
                    </StackPanel>
                </Grid>
            </Grid>
        </Border>

        <!-- Status Bar -->
        <StatusBar DockPanel.Dock="Bottom" Visibility="{Binding IsStatusBarVisible, Converter={StaticResource BoolToVisibility}}">
            <StatusBarItem MinWidth="140">
                <TextBlock>
                    <Run Text="{Binding CurrentPaneLabel, Mode=OneWay}" />
                    <Run Text=": " />
                    <Run Text="{Binding StatusText, Mode=OneWay}" />
                </TextBlock>
            </StatusBarItem>
            <Separator />
            <StatusBarItem>
                <TextBlock Text="{Binding CurrentPanePath, Mode=OneWay}" TextTrimming="CharacterEllipsis"
                           MaxWidth="600" />
            </StatusBarItem>
            <Separator />
            <StatusBarItem Visibility="{Binding CanShowQueueDetails, Converter={StaticResource BoolToVisibility}}">
                <Button Command="{Binding ToggleQueueDetailsCommand}" Padding="6,1">
                    <TextBlock Text="{Binding FileOperationQueueStatusText, Mode=OneWay}" />
                </Button>
            </StatusBarItem>
            <StatusBarItem Visibility="{Binding CanCancelFileOperationQueue, Converter={StaticResource BoolToVisibility}}">
                <Button Content="Cancel"
                        Padding="6,1"
                        Command="{Binding CancelFileOperationQueueCommand}" />
            </StatusBarItem>
            <Separator Visibility="{Binding CanShowQueueDetails, Converter={StaticResource BoolToVisibility}}" />
            <StatusBarItem Visibility="{Binding IsDualPaneMode, Converter={StaticResource BoolToVisibility}}">
                <TextBlock>
                    <Run Text="Left: " />
                    <Run Text="{Binding LeftPaneStatusText, Mode=OneWay}" />
                    <Run Text=" | Right: " />
                    <Run Text="{Binding RightPaneStatusText, Mode=OneWay}" />
                </TextBlock>
            </StatusBarItem>
        </StatusBar>

        <!-- Main Content: Folder Tree + File List -->
        <Grid>
            <Grid.ColumnDefinitions>
                <ColumnDefinition Width="250" MinWidth="150" />
                <ColumnDefinition Width="Auto" />
                <ColumnDefinition Width="*" />
            </Grid.ColumnDefinitions>

            <!-- Folder Tree Panel -->
            <DockPanel Grid.Column="0">
                <!-- Recent Folders -->
                <TextBlock DockPanel.Dock="Top" Style="{StaticResource ClassicPaneHeaderTextStyle}" Visibility="{Binding IsRecentFoldersVisible, Converter={StaticResource BoolToVisibility}}">
                    <StackPanel Orientation="Horizontal">
                        <Image Source="{StaticResource IconClock}" Width="14" Height="14" Margin="0,0,4,0" />
                        <TextBlock Text="Recent" VerticalAlignment="Center" />
                    </StackPanel>
                </TextBlock>
                <Border DockPanel.Dock="Top" Margin="4,2,4,4" Height="80" Style="{StaticResource ClassicPaneSurfaceStyle}" Visibility="{Binding IsRecentFoldersVisible, Converter={StaticResource BoolToVisibility}}">
                    <ListBox x:Name="RecentFoldersList"
                             ItemsSource="{Binding RecentFolders}"
                             SelectionChanged="RecentFolders_SelectionChanged"
                             KeyDown="RecentFolders_KeyDown"
                             DisplayMemberPath="DisplayName"
                             TabIndex="20" />
                </Border>

                <TextBlock DockPanel.Dock="Top" Text="Bookmarks" Style="{StaticResource ClassicPaneHeaderTextStyle}" Visibility="{Binding IsBookmarksVisible, Converter={StaticResource BoolToVisibility}}" />
                <DockPanel DockPanel.Dock="Top" Margin="4,4,4,2" Visibility="{Binding IsBookmarksVisible, Converter={StaticResource BoolToVisibility}}">
                    <Button Content="+ Add Current"
                            Command="{Binding AddBookmarkCommand}"
                            Padding="6,2"
                            Margin="0,0,4,0" />
                    <Button Content="- Remove"
                            Command="{Binding RemoveBookmarkCommand}"
                            CommandParameter="{Binding SelectedBookmark}"
                            Padding="6,2"
                            Margin="0,0,4,0" />
                    <Button Content="Import..."
                            Click="ImportBookmarks_Click"
                            Padding="6,2"
                            Margin="0,0,4,0" />
                    <Button Content="Export..."
                            Click="ExportBookmarks_Click"
                            Padding="6,2" />
                </DockPanel>
                <Border DockPanel.Dock="Top" Margin="4,0,4,4" Height="100" Style="{StaticResource ClassicPaneSurfaceStyle}" Visibility="{Binding IsBookmarksVisible, Converter={StaticResource BoolToVisibility}}">
                    <ListBox x:Name="BookmarkList"
                             ItemsSource="{Binding Bookmarks}"
                             SelectedItem="{Binding SelectedBookmark}"
                             SelectionChanged="BookmarkList_SelectionChanged"
                             MouseDoubleClick="BookmarkList_MouseDoubleClick"
                             KeyDown="BookmarkList_KeyDown"
                             DisplayMemberPath="Name"
                             TabIndex="30" />
                </Border>

                <TextBlock DockPanel.Dock="Top" Text="Saved Searches" Style="{StaticResource ClassicPaneHeaderTextStyle}" Visibility="{Binding IsSavedSearchesVisible, Converter={StaticResource BoolToVisibility}}" />
                <DockPanel DockPanel.Dock="Top" Margin="4,4,4,2" Visibility="{Binding IsSavedSearchesVisible, Converter={StaticResource BoolToVisibility}}">
                    <Button Content="+ Save Current"
                            Command="{Binding AddCurrentSearchCommand}"
                            Padding="6,2"
                            Margin="0,0,4,0" />
                    <Button Content="Rename"
                            Command="{Binding RenameSavedSearchCommand}"
                            CommandParameter="{Binding SelectedSavedSearch}"
                            Padding="6,2"
                            Margin="0,0,4,0" />
                    <Button Content="- Remove"
                            Command="{Binding RemoveSavedSearchCommand}"
                            CommandParameter="{Binding SelectedSavedSearch}"
                            Padding="6,2" />
                </DockPanel>
                <Border DockPanel.Dock="Top" Margin="4,0,4,4" Height="90" Style="{StaticResource ClassicPaneSurfaceStyle}" Visibility="{Binding IsSavedSearchesVisible, Converter={StaticResource BoolToVisibility}}">
                    <ListBox x:Name="SavedSearchList"
                             ItemsSource="{Binding SavedSearches}"
                             SelectedItem="{Binding SelectedSavedSearch}"
                             SelectionChanged="SavedSearchList_SelectionChanged"
                             MouseDoubleClick="SavedSearchList_MouseDoubleClick"
                             KeyDown="SavedSearchList_KeyDown"
                             DisplayMemberPath="Name"
                             TabIndex="35">
                        <ListBox.ContextMenu>
                            <ContextMenu>
                                <MenuItem Header="Run Search"
                                          Command="{Binding PlacementTarget.DataContext.RunSavedSearchCommand, RelativeSource={RelativeSource AncestorType=ContextMenu}}"
                                          CommandParameter="{Binding PlacementTarget.DataContext.SelectedSavedSearch, RelativeSource={RelativeSource AncestorType=ContextMenu}}" />
                                <MenuItem Header="Rename"
                                          Command="{Binding PlacementTarget.DataContext.RenameSavedSearchCommand, RelativeSource={RelativeSource AncestorType=ContextMenu}}"
                                          CommandParameter="{Binding PlacementTarget.DataContext.SelectedSavedSearch, RelativeSource={RelativeSource AncestorType=ContextMenu}}" />
                                <MenuItem Header="Remove"
                                          Command="{Binding PlacementTarget.DataContext.RemoveSavedSearchCommand, RelativeSource={RelativeSource AncestorType=ContextMenu}}"
                                          CommandParameter="{Binding PlacementTarget.DataContext.SelectedSavedSearch, RelativeSource={RelativeSource AncestorType=ContextMenu}}" />
                            </ContextMenu>
                        </ListBox.ContextMenu>
                    </ListBox>
                </Border>

                <TextBlock DockPanel.Dock="Top" Text="Folders" Style="{StaticResource ClassicPaneHeaderTextStyle}" />
                <Border DockPanel.Dock="Top" BorderThickness="0,0,0,1" BorderBrush="{StaticResource ClassicPaneBorderBrush}" Background="{StaticResource ClassicHeaderBrush}" Visibility="{Binding IsDrivesVisible, Converter={StaticResource BoolToVisibility}}">
                    <ScrollViewer HorizontalScrollBarVisibility="Auto" VerticalScrollBarVisibility="Disabled">
                        <ItemsControl ItemsSource="{Binding Drives}" Margin="4,2">
                            <ItemsControl.ItemsPanel>
                                <ItemsPanelTemplate>
                                    <StackPanel Orientation="Horizontal" />
                                </ItemsPanelTemplate>
                            </ItemsControl.ItemsPanel>
                            <ItemsControl.ItemTemplate>
                                <DataTemplate>
                                    <Button Command="{Binding DataContext.NavigateToDriveCommand, RelativeSource={RelativeSource AncestorType=ItemsControl}}"
                                            CommandParameter="{Binding}"
                                            ToolTip="{Binding Name}"
                                            Margin="0,0,4,0" Padding="4,2"
                                            Background="Transparent" BorderThickness="0">
                                        <StackPanel Orientation="Horizontal">
                                            <Image Source="{Binding Converter={StaticResource ShellIconConverter}}"
                                                   Width="16" Height="16" Margin="0,0,4,0" />
                                            <TextBlock Text="{Binding Name[0]}" VerticalAlignment="Center" FontWeight="SemiBold" />
                                        </StackPanel>
                                    </Button>
                                </DataTemplate>
                            </ItemsControl.ItemTemplate>
                        </ItemsControl>
                    </ScrollViewer>
                </Border>
                <Border Margin="4,0,4,4" Style="{StaticResource ClassicPaneSurfaceStyle}">
                    <TreeView x:Name="FolderTree" ItemsSource="{Binding FolderTreeRoots}"
                              VirtualizingStackPanel.IsVirtualizing="True"
                              VirtualizingStackPanel.VirtualizationMode="Recycling"
                              AllowDrop="True"
                              DragOver="FolderTree_DragOver"
                              Drop="FolderTree_Drop"
                              TabIndex="40">
                        <TreeView.ItemContainerStyle>
                            <Style TargetType="TreeViewItem">
                                <Setter Property="IsExpanded" Value="{Binding IsExpanded, Mode=TwoWay}" />
                                <Setter Property="IsSelected" Value="{Binding IsSelected, Mode=TwoWay}" />
                                <Setter Property="AllowDrop" Value="True" />
                                <EventSetter Event="Selected" Handler="TreeViewItem_Selected" />
                            </Style>
                        </TreeView.ItemContainerStyle>
                        <TreeView.ItemTemplate>
                            <HierarchicalDataTemplate DataType="{x:Type vm:FolderTreeNodeViewModel}"
                                                      ItemsSource="{Binding Children}">
                                <StackPanel Orientation="Horizontal" Margin="2">
                                    <Image Source="{Binding Converter={StaticResource ShellIconConverter}}"
                                           Width="16"
                                           Height="16"
                                           Margin="0,0,6,0" />
                                    <TextBlock Text="{Binding Name}" />
                                </StackPanel>
                            </HierarchicalDataTemplate>
                        </TreeView.ItemTemplate>
                    </TreeView>
                </Border>
            </DockPanel>

            <!-- Splitter -->
            <GridSplitter Grid.Column="1" Width="4" HorizontalAlignment="Center"
                          VerticalAlignment="Stretch" Background="#96B3D8" />

            <!-- File List Panel -->
            <Grid Grid.Column="2">
                <Grid.RowDefinitions>
                    <RowDefinition Height="Auto" />
                    <RowDefinition Height="Auto" />
                    <RowDefinition Height="Auto" />
                    <RowDefinition Height="*" />
                </Grid.RowDefinitions>

                <!-- Filter Bar -->
                <DockPanel Grid.Row="0" Margin="2,2,2,0">
                    <TextBlock DockPanel.Dock="Left" Text="Filter:" VerticalAlignment="Center"
                               Margin="4,0,4,0" />
                    <Button DockPanel.Dock="Right" Content="&#x2715;" FontSize="10"
                            Padding="4,1" Margin="2,0,0,0" ToolTip="Clear filter"
                            Click="ClearFilter_Click" />
                    <TextBox x:Name="FilterTextBox"
                             Text="{Binding CurrentPaneFileList.FilterText, UpdateSourceTrigger=PropertyChanged}"
                             VerticalContentAlignment="Center" Padding="4,2"
                             TabIndex="50" />
                </DockPanel>

                <!-- Search Bar (Ctrl+E) -->
                <DockPanel x:Name="SearchBar" Grid.Row="1" Margin="2,2,2,0"
                           Visibility="{Binding CurrentPaneFileList.IsSearchVisible, Converter={StaticResource BoolToVisibility}, FallbackValue=Collapsed}">
                    <Image DockPanel.Dock="Left" Source="{StaticResource IconSearch}"
                           Width="14" Height="14" Margin="4,0,2,0" />
                    <TextBlock DockPanel.Dock="Left" Text="Search:" VerticalAlignment="Center"
                               Margin="2,0,4,0" />
                    <Button DockPanel.Dock="Right" Content="&#x2715;" FontSize="10"
                            Padding="4,1" Margin="2,0,0,0" ToolTip="Close search"
                            Command="{Binding CloseSearchCommand}" />
                    <Button DockPanel.Dock="Right" Content="Save" Padding="6,1" Margin="2,0,0,0"
                            Command="{Binding AddCurrentSearchCommand}" />
                    <Button DockPanel.Dock="Right" Content="Go" Padding="6,1" Margin="2,0,0,0"
                            Command="{Binding ExecuteSearchCommand}" />
                    <TextBox x:Name="SearchTextBox"
                             Text="{Binding CurrentPaneFileList.SearchText, UpdateSourceTrigger=PropertyChanged}"
                             VerticalContentAlignment="Center" Padding="4,2"
                             KeyDown="SearchTextBox_KeyDown"
                             TabIndex="60" />
                </DockPanel>

                <!-- Search Results Banner -->
                <Border Grid.Row="2" Margin="2,2,2,0" Padding="4,2"
                        Background="#FFF8DC" BorderBrush="#DAA520" BorderThickness="1" CornerRadius="2"
                        Visibility="{Binding CurrentPaneFileList.IsShowingSearchResults, Converter={StaticResource BoolToVisibility}, FallbackValue=Collapsed}">
                    <DockPanel>
                        <Button DockPanel.Dock="Right" Content="&#x2715;" FontSize="10"
                                Padding="4,1" ToolTip="Clear search results"
                                Background="Transparent" BorderThickness="0"
                                Command="{Binding ClearSearchResultsCommand}" />
                        <TextBlock Text="{Binding CurrentPaneFileList.SearchResultsText}"
                                   VerticalAlignment="Center" />
                    </DockPanel>
                </Border>

                <!-- Main file area: Left pane | Splitter | Right pane | Splitter | Preview -->
                <Grid Grid.Row="3">
                    <Grid.ColumnDefinitions>
                        <ColumnDefinition Width="*" />
                        <ColumnDefinition x:Name="DualPaneSplitterCol" Width="0" />
                        <ColumnDefinition x:Name="DualPaneCol" Width="0" />
                        <ColumnDefinition x:Name="PreviewSplitterCol" Width="0" />
                        <ColumnDefinition x:Name="PreviewCol" Width="0" />
                    </Grid.ColumnDefinitions>

                    <!-- Left Pane (main file list) -->
                    <ListView x:Name="FileListView"
                              Grid.Column="0"
                              ItemsSource="{Binding ActiveTab.FileList.Items}"
                              SelectedItem="{Binding ActiveTab.FileList.SelectedItem}"
                              BorderBrush="{StaticResource ClassicPaneBorderBrush}"
                              BorderThickness="1"
                              AllowDrop="True"
                              SelectionMode="Extended"
                              VirtualizingStackPanel.IsVirtualizing="True"
                              VirtualizingStackPanel.VirtualizationMode="Recycling"
                              SelectionChanged="FileList_SelectionChanged"
                              GotKeyboardFocus="FileList_GotKeyboardFocus"
                              PreviewMouseLeftButtonDown="FileList_PreviewMouseLeftButtonDown"
                              MouseMove="FileList_MouseMove"
                              DragEnter="FileList_DragEnter"
                              DragOver="FileList_DragOver"
                              Drop="FileList_Drop"
                              MouseDoubleClick="FileList_MouseDoubleClick"
                              ContextMenuOpening="FileList_ContextMenuOpening"
                              GridViewColumnHeader.Click="FileListHeader_Click"
                              TabIndex="70">
                        <ListView.ContextMenu>
                            <ContextMenu>
                                <MenuItem x:Name="OpenMenuItem" Header="Open" Command="{Binding OpenSelectedItemCommand}" />
                                <MenuItem x:Name="BrowseArchiveMenuItem" Header="Browse Archive" Command="{Binding BrowseArchiveCommand}" />
                                <Separator x:Name="ItemSeparator1" />
                                <MenuItem x:Name="CutMenuItem" Header="Cut" Command="{Binding CutCommand}" />
                                <MenuItem x:Name="CopyMenuItem" Header="Copy" Command="{Binding CopyCommand}" />
                                <MenuItem x:Name="PasteMenuItem" Header="Paste" Command="{Binding PasteCommand}" />
                                <Separator x:Name="ItemSeparator2" />
                                <MenuItem x:Name="DeleteMenuItem" Header="Delete" Command="{Binding DeleteCommand}" />
                                <MenuItem x:Name="RenameMenuItem" Header="Rename" Command="{Binding RenameCommand}" />
                                <MenuItem x:Name="NewFolderMenuItem" Header="New Folder" Command="{Binding NewFolderCommand}" />
                                <MenuItem x:Name="RefreshMenuItem" Header="Refresh" Command="{Binding RefreshCommand}" />
                                <MenuItem x:Name="ExtractArchiveMenuItem" Header="Extract Archive..." Command="{Binding ExtractArchiveCommand}" />
                                <Separator x:Name="PropertiesSeparator" />
                                <MenuItem x:Name="OpenInExplorerMenuItem" Header="Open in Explorer" Click="OpenInExplorer_Click" />
                                <MenuItem x:Name="PropertiesMenuItem" Header="Properties" Command="{Binding ShowPropertiesCommand}" />
                            </ContextMenu>
                        </ListView.ContextMenu>
                        <ListView.View>
                            <GridView>
                                <GridViewColumn Header="Name" Width="350"
                                                CellTemplate="{StaticResource DetailsNameCellTemplate}" />
                                <GridViewColumn Header="Size" Width="100"
                                                DisplayMemberBinding="{Binding DisplaySize}" />
                                <GridViewColumn Header="Type" Width="120"
                                                DisplayMemberBinding="{Binding TypeDescription}" />
                                <GridViewColumn Header="Date Modified" Width="160"
                                                DisplayMemberBinding="{Binding DateModified, StringFormat={}{0:yyyy-MM-dd HH:mm}}" />
                            </GridView>
                        </ListView.View>
                    </ListView>

                    <Popup x:Name="InlineRenamePopup"
                           Grid.Column="0"
                           PlacementTarget="{Binding ElementName=FileListView}"
                           Placement="Relative"
                           StaysOpen="False"
                           AllowsTransparency="True">
                        <Border BorderBrush="#999999" BorderThickness="1" Background="White" Padding="1">
                            <TextBox x:Name="InlineRenameTextBox"
                                     MinWidth="220"
                                     KeyDown="InlineRenameTextBox_KeyDown"
                                     LostKeyboardFocus="InlineRenameTextBox_LostKeyboardFocus" />
                        </Border>
                    </Popup>

                    <!-- Dual Pane Splitter -->
                    <GridSplitter Grid.Column="1" Width="4" HorizontalAlignment="Center"
                                  VerticalAlignment="Stretch" Background="#96B3D8" />

                    <!-- Right Pane (dual pane mode) -->
                    <Grid Grid.Column="2">
                        <Grid.RowDefinitions>
                            <RowDefinition Height="Auto" />
                            <RowDefinition Height="*" />
                        </Grid.RowDefinitions>
                        <Border x:Name="RightPaneHeader" Grid.Row="0" Background="{StaticResource ClassicHeaderBrush}"
                                BorderBrush="{StaticResource ClassicPaneBorderBrush}" BorderThickness="0,0,0,1"
                                Padding="4,2"
                                MouseLeftButtonDown="RightPaneHeader_MouseLeftButtonDown">
                            <Grid>
                                <Grid.ColumnDefinitions>
                                    <ColumnDefinition Width="Auto" />
                                    <ColumnDefinition Width="*" />
                                    <ColumnDefinition Width="Auto" />
                                </Grid.ColumnDefinitions>
                                <TextBlock Grid.Column="0" Text="Right Pane"
                                           FontWeight="SemiBold" Margin="0,0,8,0"
                                           VerticalAlignment="Center" />
                                <Grid Grid.Column="1">
                                    <TextBlock x:Name="RightPaneAddressDisplay"
                                               Text="{Binding RightPaneAddressText}"
                                               TextTrimming="CharacterEllipsis"
                                               VerticalAlignment="Center" />
                                    <DockPanel x:Name="RightPaneAddressEditorPanel"
                                               Visibility="Collapsed">
                                        <Button DockPanel.Dock="Right"
                                                ToolTip="Go"
                                                Padding="4,2"
                                                MinWidth="24"
                                                Margin="4,0,0,0"
                                                Click="RightPaneAddressGo_Click">
                                            <Image Source="{StaticResource IconGo}" Width="14" Height="14" />
                                        </Button>
                                        <Grid>
                                            <TextBox x:Name="RightPaneAddressBox"
                                                     Text="{Binding RightPaneAddressText, UpdateSourceTrigger=PropertyChanged}"
                                                     KeyDown="RightPaneAddressBox_KeyDown"
                                                     LostKeyboardFocus="RightPaneAddressBox_LostFocus"
                                                     TextChanged="RightPaneAddressBox_TextChanged"
                                                     VerticalContentAlignment="Center"
                                                     Padding="4,1"
                                                     TabIndex="75" />
                                            <Popup x:Name="RightPaneAutoCompletePopup"
                                                   PlacementTarget="{Binding ElementName=RightPaneAddressBox}"
                                                   Placement="Bottom"
                                                   StaysOpen="False"
                                                   AllowsTransparency="True"
                                                   Width="{Binding ActualWidth, ElementName=RightPaneAddressBox}">
                                                <Border BorderBrush="#999999" BorderThickness="1" Background="White"
                                                        MaxHeight="250">
                                                    <ListBox x:Name="RightPaneAutoCompleteList"
                                                             ItemsSource="{Binding RightPaneAddressSuggestions}"
                                                             MaxHeight="240"
                                                             PreviewMouseLeftButtonUp="RightPaneAutoComplete_Select" />
                                                </Border>
                                            </Popup>
                                        </Grid>
                                    </DockPanel>
                                </Grid>
                                <TextBlock x:Name="RightPaneStatusBlock"
                                           Grid.Column="2"
                                           Text="{Binding RightPaneStatusText}"
                                           Foreground="#5A6F89"
                                           Margin="8,0,0,0"
                                           VerticalAlignment="Center"
                                           FontSize="10" />
                            </Grid>
                        </Border>
                        <ListView x:Name="RightPaneListView"
                                  Grid.Row="1"
                                  ItemsSource="{Binding RightPaneTab.FileList.Items}"
                                  SelectedItem="{Binding RightPaneTab.FileList.SelectedItem}"
                                  BorderBrush="{StaticResource ClassicPaneBorderBrush}"
                                  BorderThickness="1"
                                  AllowDrop="True"
                                  SelectionMode="Extended"
                                  VirtualizingStackPanel.IsVirtualizing="True"
                                  VirtualizingStackPanel.VirtualizationMode="Recycling"
                                  SelectionChanged="RightPane_SelectionChanged"
                                  GotKeyboardFocus="RightPane_GotKeyboardFocus"
                                  PreviewMouseLeftButtonDown="RightPane_PreviewMouseLeftButtonDown"
                                  MouseMove="RightPane_MouseMove"
                                  DragEnter="RightPane_DragEnter"
                                  DragOver="RightPane_DragOver"
                                  Drop="RightPane_Drop"
                                  MouseDoubleClick="RightPane_MouseDoubleClick"
                                  ContextMenuOpening="RightPane_ContextMenuOpening"
                                  GridViewColumnHeader.Click="RightPaneHeader_Click"
                                  TabIndex="80">
                            <ListView.ContextMenu>
                                <ContextMenu>
                                    <MenuItem x:Name="RightOpenMenuItem" Header="Open" Command="{Binding OpenSelectedItemCommand}" />
                                    <MenuItem x:Name="RightBrowseArchiveMenuItem" Header="Browse Archive" Command="{Binding BrowseArchiveCommand}" />
                                    <Separator x:Name="RightItemSeparator1" />
                                    <MenuItem x:Name="RightCutMenuItem" Header="Cut" Command="{Binding CutCommand}" />
                                    <MenuItem x:Name="RightCopyMenuItem" Header="Copy" Command="{Binding CopyCommand}" />
                                    <MenuItem x:Name="RightPasteMenuItem" Header="Paste" Command="{Binding PasteCommand}" />
                                    <Separator x:Name="RightItemSeparator2" />
                                    <MenuItem x:Name="RightDeleteMenuItem" Header="Delete" Command="{Binding DeleteCommand}" />
                                    <MenuItem x:Name="RightRenameMenuItem" Header="Rename" Command="{Binding RenameCommand}" />
                                    <MenuItem x:Name="RightNewFolderMenuItem" Header="New Folder" Command="{Binding NewFolderCommand}" />
                                    <MenuItem x:Name="RightRefreshMenuItem" Header="Refresh" Command="{Binding RefreshCommand}" />
                                    <MenuItem x:Name="RightExtractArchiveMenuItem" Header="Extract Archive..." Command="{Binding ExtractArchiveCommand}" />
                                    <Separator x:Name="RightPropertiesSeparator" />
                                    <MenuItem x:Name="RightOpenInExplorerMenuItem" Header="Open in Explorer" Click="OpenInExplorer_Click" />
                                    <MenuItem x:Name="RightPropertiesMenuItem" Header="Properties" Command="{Binding ShowPropertiesCommand}" />
                                </ContextMenu>
                            </ListView.ContextMenu>
                            <ListView.View>
                                <GridView>
                                    <GridViewColumn Header="Name" Width="250"
                                                    CellTemplate="{StaticResource DetailsNameCellTemplate}" />
                                    <GridViewColumn Header="Size" Width="80"
                                                    DisplayMemberBinding="{Binding DisplaySize}" />
                                    <GridViewColumn Header="Type" Width="100"
                                                    DisplayMemberBinding="{Binding TypeDescription}" />
                                    <GridViewColumn Header="Date Modified" Width="140"
                                                    DisplayMemberBinding="{Binding DateModified, StringFormat={}{0:yyyy-MM-dd HH:mm}}" />
                                </GridView>
                            </ListView.View>
                        </ListView>
                    </Grid>

                    <!-- Preview Splitter -->
                    <GridSplitter Grid.Column="3" Width="4" HorizontalAlignment="Center"
                                  VerticalAlignment="Stretch" Background="#96B3D8" />

                    <!-- Preview Panel -->
                    <Border x:Name="PreviewPanel" Grid.Column="4" Style="{StaticResource ClassicPaneSurfaceStyle}" Margin="0"
                            Focusable="True" KeyboardNavigation.TabIndex="90">
                        <DockPanel>
                            <TextBlock DockPanel.Dock="Top" Text="{Binding PreviewFileName}"
                                       FontWeight="SemiBold" Padding="8,6,8,2"
                                       TextTrimming="CharacterEllipsis" />
                            <TextBlock DockPanel.Dock="Top" Text="{Binding PreviewFileInfo}"
                                       Foreground="Gray" Padding="8,0,8,4" FontSize="10" />
                            <Border DockPanel.Dock="Top" BorderBrush="{StaticResource ClassicPaneBorderBrush}"
                                    BorderThickness="0,1,0,0" Margin="0,0,0,0" />
                            <!-- Image preview -->
                            <Image DockPanel.Dock="Top"
                                   Source="{Binding PreviewImageSource}"
                                   Stretch="Uniform" MaxHeight="400"
                                   Margin="4" RenderOptions.BitmapScalingMode="HighQuality"
                                   Visibility="{Binding HasPreviewImage, Converter={StaticResource BoolToVisibility}}" />
                            <!-- Text preview -->
                            <ScrollViewer VerticalScrollBarVisibility="Auto"
                                          HorizontalScrollBarVisibility="Auto"
                                          Visibility="{Binding HasPreviewText, Converter={StaticResource BoolToVisibility}}">
                                <TextBox Text="{Binding PreviewText, Mode=OneWay}"
                                         IsReadOnly="True" TextWrapping="Wrap"
                                         FontFamily="Consolas" FontSize="11"
                                         BorderThickness="0" Background="Transparent"
                                         Padding="8,4" />
                            </ScrollViewer>
                            <TextBlock Text="{Binding PreviewStatusText}"
                                       Margin="8"
                                       Foreground="#5A6F89"
                                       TextWrapping="Wrap"
                                       Visibility="{Binding HasPreviewStatus, Converter={StaticResource BoolToVisibility}}" />
                        </DockPanel>
                    </Border>
                </Grid>
            </Grid>
        </Grid>
    </DockPanel>
</Window>
