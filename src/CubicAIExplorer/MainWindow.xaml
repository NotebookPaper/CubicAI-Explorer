<Window x:Class="CubicAIExplorer.MainWindow"
        xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
        xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
        xmlns:vm="clr-namespace:CubicAIExplorer.ViewModels"
        xmlns:models="clr-namespace:CubicAIExplorer.Models"
        Title="CubicAI Explorer" Height="700" Width="1100"
        WindowStartupLocation="CenterScreen"
        d:DataContext="{d:DesignInstance vm:MainViewModel}"
        xmlns:d="http://schemas.microsoft.com/expression/blend/2008"
        xmlns:mc="http://schemas.openxmlformats.org/markup-compatibility/2006"
        mc:Ignorable="d">

    <Window.InputBindings>
        <KeyBinding Key="T" Modifiers="Ctrl" Command="{Binding NewTabCommand}" />
        <KeyBinding Key="W" Modifiers="Ctrl" Command="{Binding CloseTabCommand}" CommandParameter="{Binding ActiveTab}" />
        <KeyBinding Key="L" Modifiers="Ctrl" Command="{Binding NavigateToAddressCommand}" />
        <KeyBinding Key="D" Modifiers="Ctrl" Command="{Binding AddBookmarkCommand}" />
        <KeyBinding Key="Z" Modifiers="Ctrl" Command="{Binding ActiveTab.FileList.UndoCommand}" />
        <KeyBinding Key="Y" Modifiers="Ctrl" Command="{Binding ActiveTab.FileList.RedoCommand}" />
        <KeyBinding Key="Z" Modifiers="Ctrl+Shift" Command="{Binding ActiveTab.FileList.RedoCommand}" />
        <KeyBinding Key="C" Modifiers="Ctrl" Command="{Binding ActiveTab.FileList.CopyCommand}" />
        <KeyBinding Key="X" Modifiers="Ctrl" Command="{Binding ActiveTab.FileList.CutCommand}" />
        <KeyBinding Key="V" Modifiers="Ctrl" Command="{Binding ActiveTab.FileList.PasteCommand}" />
        <KeyBinding Key="Delete" Command="{Binding ActiveTab.FileList.DeleteCommand}" />
        <KeyBinding Key="Delete" Modifiers="Shift" Command="{Binding ActiveTab.FileList.PermanentDeleteCommand}" />
        <KeyBinding Key="F2" Command="{Binding ActiveTab.FileList.RenameCommand}" />
        <KeyBinding Key="F5" Command="{Binding ActiveTab.FileList.RefreshCommand}" />
        <KeyBinding Key="N" Modifiers="Ctrl+Shift" Command="{Binding ActiveTab.FileList.NewFolderCommand}" />
        <KeyBinding Key="A" Modifiers="Ctrl" Command="{Binding ActiveTab.FileList.SelectAllCommand}" />
        <KeyBinding Key="BrowserBack" Command="{Binding ActiveTab.GoBackCommand}" />
        <KeyBinding Key="BrowserForward" Command="{Binding ActiveTab.GoForwardCommand}" />
        <KeyBinding Key="Back" Command="{Binding NavigateUpCommand}" />
        <KeyBinding Key="Return" Modifiers="Alt" Command="{Binding ActiveTab.FileList.ShowPropertiesCommand}" />
        <KeyBinding Key="E" Modifiers="Ctrl" Command="{Binding ActiveTab.FileList.SearchInFolderCommand}" />
    </Window.InputBindings>

    <DockPanel>
        <!-- Menu Bar -->
        <Menu DockPanel.Dock="Top">
            <MenuItem Header="_File">
                <MenuItem Header="_New Tab" InputGestureText="Ctrl+T" Command="{Binding NewTabCommand}" />
                <MenuItem Header="_Close Tab" InputGestureText="Ctrl+W" Command="{Binding CloseTabCommand}" CommandParameter="{Binding ActiveTab}" />
                <Separator />
                <MenuItem Header="E_xit" InputGestureText="Alt+F4" Click="OnExitClick" />
            </MenuItem>
            <MenuItem Header="_Edit">
                <MenuItem Header="{Binding ActiveTab.FileList.UndoDescription}" InputGestureText="Ctrl+Z" Command="{Binding ActiveTab.FileList.UndoCommand}" />
                <MenuItem Header="{Binding ActiveTab.FileList.RedoDescription}" InputGestureText="Ctrl+Y" Command="{Binding ActiveTab.FileList.RedoCommand}" />
                <Separator />
                <MenuItem Header="Clear History" Command="{Binding ActiveTab.FileList.ClearHistoryCommand}" />
            </MenuItem>
            <MenuItem Header="_View">
                <MenuItem Header="_Details" Click="ViewMode_Details_Click" />
                <MenuItem Header="_List" Click="ViewMode_List_Click" />
                <MenuItem Header="_Tiles" Click="ViewMode_Tiles_Click" />
                <Separator />
                <MenuItem Header="_Search in Folder..." InputGestureText="Ctrl+E"
                          Command="{Binding ActiveTab.FileList.SearchInFolderCommand}" />
                <Separator />
                <MenuItem Header="Show _Hidden Files" IsCheckable="True"
                          IsChecked="{Binding ActiveTab.FileList.ShowHiddenFiles}" />
            </MenuItem>
            <MenuItem Header="_Help">
                <MenuItem Header="_About CubicAI Explorer" Click="OnAboutClick" />
            </MenuItem>
        </Menu>

        <!-- Toolbar -->
        <ToolBarTray DockPanel.Dock="Top" IsLocked="True">
            <ToolBar Band="0" BandIndex="0">
                <!-- Navigation -->
                <Button Command="{Binding ActiveTab.GoBackCommand}" ToolTip="Back (Alt+Left)" Padding="4,2" MinWidth="26">
                    <Image Source="{StaticResource IconBack}" Width="16" Height="16" />
                </Button>
                <Button Command="{Binding ActiveTab.GoForwardCommand}" ToolTip="Forward (Alt+Right)" Padding="4,2" MinWidth="26">
                    <Image Source="{StaticResource IconForward}" Width="16" Height="16" />
                </Button>
                <Button Command="{Binding NavigateUpCommand}" ToolTip="Up (Backspace)" Padding="4,2" MinWidth="26">
                    <Image Source="{StaticResource IconUp}" Width="16" Height="16" />
                </Button>
                <Separator />
                <!-- File Operations -->
                <Button Command="{Binding ActiveTab.FileList.CutCommand}" ToolTip="Cut (Ctrl+X)" Padding="4,2" MinWidth="26">
                    <Image Source="{StaticResource IconCut}" Width="16" Height="16" />
                </Button>
                <Button Command="{Binding ActiveTab.FileList.CopyCommand}" ToolTip="Copy (Ctrl+C)" Padding="4,2" MinWidth="26">
                    <Image Source="{StaticResource IconCopy}" Width="16" Height="16" />
                </Button>
                <Button Command="{Binding ActiveTab.FileList.PasteCommand}" ToolTip="Paste (Ctrl+V)" Padding="4,2" MinWidth="26">
                    <Image Source="{StaticResource IconPaste}" Width="16" Height="16" />
                </Button>
                <Separator />
                <Button Command="{Binding ActiveTab.FileList.DeleteCommand}" ToolTip="Delete (Del)" Padding="4,2" MinWidth="26">
                    <Image Source="{StaticResource IconDelete}" Width="16" Height="16" />
                </Button>
                <Separator />
                <Button Command="{Binding ActiveTab.FileList.UndoCommand}" ToolTip="{Binding ActiveTab.FileList.UndoDescription}" Padding="4,2" MinWidth="26">
                    <Image Source="{StaticResource IconUndo}" Width="16" Height="16" />
                </Button>
                <Button Command="{Binding ActiveTab.FileList.RedoCommand}" ToolTip="{Binding ActiveTab.FileList.RedoDescription}" Padding="4,2" MinWidth="26">
                    <Image Source="{StaticResource IconRedo}" Width="16" Height="16" />
                </Button>
                <Separator />
                <Button Command="{Binding ActiveTab.FileList.RefreshCommand}" ToolTip="Refresh (F5)" Padding="4,2" MinWidth="26">
                    <Image Source="{StaticResource IconRefresh}" Width="16" Height="16" />
                </Button>
            </ToolBar>
        </ToolBarTray>

        <!-- Address / Breadcrumb Bar -->
        <Border DockPanel.Dock="Top" Background="{StaticResource ClassicChromeBrush}"
                BorderBrush="{StaticResource ClassicChromeBorderBrush}" BorderThickness="0,0,0,1"
                Padding="4,2">
            <Grid>
                <!-- Breadcrumb mode -->
                <DockPanel x:Name="BreadcrumbBar" Visibility="Visible"
                           MouseLeftButtonDown="BreadcrumbBar_MouseDown">
                    <Button DockPanel.Dock="Right" Command="{Binding NavigateToAddressCommand}"
                            ToolTip="Go" Padding="4,2" MinWidth="24" Margin="2,0,0,0">
                        <Image Source="{StaticResource IconGo}" Width="14" Height="14" />
                    </Button>
                    <ItemsControl x:Name="BreadcrumbItems" ItemsSource="{Binding BreadcrumbSegments}"
                                  VerticalAlignment="Center">
                        <ItemsControl.ItemsPanel>
                            <ItemsPanelTemplate>
                                <StackPanel Orientation="Horizontal" />
                            </ItemsPanelTemplate>
                        </ItemsControl.ItemsPanel>
                        <ItemsControl.ItemTemplate>
                            <DataTemplate>
                                <StackPanel Orientation="Horizontal">
                                    <TextBlock Text="\" Foreground="#999999" VerticalAlignment="Center"
                                               Margin="0,0,0,0" FontSize="11"
                                               Visibility="{Binding SeparatorVisibility}" />
                                    <Button Content="{Binding DisplayName}" Tag="{Binding FullPath}"
                                            Click="BreadcrumbSegment_Click"
                                            Background="Transparent" BorderThickness="0"
                                            Padding="3,1" Cursor="Hand"
                                            FontSize="12">
                                        <Button.Style>
                                            <Style TargetType="Button">
                                                <Style.Triggers>
                                                    <Trigger Property="IsMouseOver" Value="True">
                                                        <Setter Property="Foreground" Value="#2255AA" />
                                                        <Setter Property="Background" Value="#E0EEFF" />
                                                    </Trigger>
                                                </Style.Triggers>
                                            </Style>
                                        </Button.Style>
                                    </Button>
                                </StackPanel>
                            </DataTemplate>
                        </ItemsControl.ItemTemplate>
                    </ItemsControl>
                </DockPanel>

                <!-- Edit mode (TextBox) -->
                <DockPanel x:Name="AddressBarPanel" Visibility="Collapsed">
                    <Button DockPanel.Dock="Right" Command="{Binding NavigateToAddressCommand}"
                            ToolTip="Go" Padding="4,2" MinWidth="24" Margin="2,0,0,0"
                            Click="AddressBarGo_Click">
                        <Image Source="{StaticResource IconGo}" Width="14" Height="14" />
                    </Button>
                    <TextBox x:Name="AddressBar"
                             Text="{Binding AddressBarText, UpdateSourceTrigger=PropertyChanged}"
                             KeyDown="AddressBar_KeyDown"
                             LostKeyboardFocus="AddressBar_LostFocus"
                             VerticalContentAlignment="Center" Padding="4,2" />
                </DockPanel>
            </Grid>
        </Border>

        <!-- Tab Bar -->
        <DockPanel DockPanel.Dock="Top" Background="{StaticResource ClassicChromeBrush}">
            <Button DockPanel.Dock="Right" Command="{Binding NewTabCommand}"
                    Content="+" FontSize="14" Padding="8,2" Margin="2"
                    ToolTip="New Tab (Ctrl+T)" />
            <TabControl ItemsSource="{Binding Tabs}" SelectedItem="{Binding ActiveTab}"
                        Padding="0" Margin="0">
                <TabControl.ItemTemplate>
                    <DataTemplate DataType="{x:Type vm:TabViewModel}">
                        <DockPanel MinWidth="80" MaxWidth="200">
                            <DockPanel.ContextMenu>
                                <ContextMenu>
                                    <MenuItem Header="Duplicate Tab" Click="DuplicateTab_Click"
                                              Tag="{Binding}" />
                                    <Separator />
                                    <MenuItem Header="Close Tab" Click="CloseTab_Click"
                                              Tag="{Binding}" />
                                    <MenuItem Header="Close Other Tabs" Click="CloseOtherTabs_Click"
                                              Tag="{Binding}" />
                                </ContextMenu>
                            </DockPanel.ContextMenu>
                            <Button DockPanel.Dock="Right" Content="x" FontSize="10"
                                    Padding="4,0" Margin="4,0,0,0" BorderThickness="0"
                                    Background="Transparent"
                                    Command="{Binding DataContext.CloseTabCommand, RelativeSource={RelativeSource AncestorType=Window}}"
                                    CommandParameter="{Binding}" ToolTip="Close Tab" />
                            <TextBlock Text="{Binding Title}" TextTrimming="CharacterEllipsis"
                                       VerticalAlignment="Center" Margin="4,2" />
                        </DockPanel>
                    </DataTemplate>
                </TabControl.ItemTemplate>
                <TabControl.ContentTemplate>
                    <DataTemplate DataType="{x:Type vm:TabViewModel}">
                        <!-- Empty - we display content below the tab strip -->
                        <Border />
                    </DataTemplate>
                </TabControl.ContentTemplate>
            </TabControl>
        </DockPanel>

        <!-- Status Bar -->
        <StatusBar DockPanel.Dock="Bottom">
            <StatusBarItem MinWidth="140">
                <TextBlock Text="{Binding StatusText}" />
            </StatusBarItem>
            <Separator />
            <StatusBarItem>
                <TextBlock Text="{Binding ActiveTab.CurrentPath}" TextTrimming="CharacterEllipsis"
                           MaxWidth="600" />
            </StatusBarItem>
        </StatusBar>

        <!-- Main Content: Folder Tree + File List -->
        <Grid>
            <Grid.ColumnDefinitions>
                <ColumnDefinition Width="250" MinWidth="150" />
                <ColumnDefinition Width="Auto" />
                <ColumnDefinition Width="*" />
            </Grid.ColumnDefinitions>

            <!-- Folder Tree Panel -->
            <DockPanel Grid.Column="0">
                <!-- Recent Folders -->
                <TextBlock DockPanel.Dock="Top" Style="{StaticResource ClassicPaneHeaderTextStyle}">
                    <StackPanel Orientation="Horizontal">
                        <Image Source="{StaticResource IconClock}" Width="14" Height="14" Margin="0,0,4,0" />
                        <TextBlock Text="Recent" VerticalAlignment="Center" />
                    </StackPanel>
                </TextBlock>
                <Border DockPanel.Dock="Top" Margin="4,2,4,4" Height="80" Style="{StaticResource ClassicPaneSurfaceStyle}">
                    <ListBox ItemsSource="{Binding RecentFolders}"
                             SelectionChanged="RecentFolders_SelectionChanged"
                             DisplayMemberPath="DisplayName" />
                </Border>

                <TextBlock DockPanel.Dock="Top" Text="Bookmarks" Style="{StaticResource ClassicPaneHeaderTextStyle}" />
                <DockPanel DockPanel.Dock="Top" Margin="4,4,4,2">
                    <Button Content="+ Add Current"
                            Command="{Binding AddBookmarkCommand}"
                            Padding="6,2"
                            Margin="0,0,4,0" />
                    <Button Content="- Remove"
                            Command="{Binding RemoveBookmarkCommand}"
                            CommandParameter="{Binding SelectedBookmark}"
                            Padding="6,2" />
                </DockPanel>
                <Border DockPanel.Dock="Top" Margin="4,0,4,4" Height="100" Style="{StaticResource ClassicPaneSurfaceStyle}">
                    <ListBox x:Name="BookmarkList"
                             ItemsSource="{Binding Bookmarks}"
                             SelectedItem="{Binding SelectedBookmark}"
                             SelectionChanged="BookmarkList_SelectionChanged"
                             MouseDoubleClick="BookmarkList_MouseDoubleClick"
                             DisplayMemberPath="Name" />
                </Border>

                <TextBlock DockPanel.Dock="Top" Text="Folders" Style="{StaticResource ClassicPaneHeaderTextStyle}" />
                <Border Margin="4,0,4,4" Style="{StaticResource ClassicPaneSurfaceStyle}">
                    <TreeView x:Name="FolderTree" ItemsSource="{Binding FolderTreeRoots}"
                              VirtualizingStackPanel.IsVirtualizing="True"
                              VirtualizingStackPanel.VirtualizationMode="Recycling"
                              AllowDrop="True"
                              DragOver="FolderTree_DragOver"
                              Drop="FolderTree_Drop">
                        <TreeView.ItemContainerStyle>
                            <Style TargetType="TreeViewItem">
                                <Setter Property="IsExpanded" Value="{Binding IsExpanded, Mode=TwoWay}" />
                                <Setter Property="IsSelected" Value="{Binding IsSelected, Mode=TwoWay}" />
                                <Setter Property="AllowDrop" Value="True" />
                                <EventSetter Event="Selected" Handler="TreeViewItem_Selected" />
                            </Style>
                        </TreeView.ItemContainerStyle>
                        <TreeView.ItemTemplate>
                            <HierarchicalDataTemplate DataType="{x:Type vm:FolderTreeNodeViewModel}"
                                                      ItemsSource="{Binding Children}">
                                <StackPanel Orientation="Horizontal" Margin="2">
                                    <Image Source="{Binding Converter={StaticResource ShellIconConverter}}"
                                           Width="16"
                                           Height="16"
                                           Margin="0,0,6,0" />
                                    <TextBlock Text="{Binding Name}" />
                                </StackPanel>
                            </HierarchicalDataTemplate>
                        </TreeView.ItemTemplate>
                    </TreeView>
                </Border>
            </DockPanel>

            <!-- Splitter -->
            <GridSplitter Grid.Column="1" Width="4" HorizontalAlignment="Center"
                          VerticalAlignment="Stretch" Background="#96B3D8" />

            <!-- File List Panel -->
            <Grid Grid.Column="2">
                <Grid.RowDefinitions>
                    <RowDefinition Height="Auto" />
                    <RowDefinition Height="Auto" />
                    <RowDefinition Height="Auto" />
                    <RowDefinition Height="*" />
                </Grid.RowDefinitions>

                <!-- Filter Bar -->
                <DockPanel Grid.Row="0" Margin="2,2,2,0">
                    <TextBlock DockPanel.Dock="Left" Text="Filter:" VerticalAlignment="Center"
                               Margin="4,0,4,0" />
                    <Button DockPanel.Dock="Right" Content="&#x2715;" FontSize="10"
                            Padding="4,1" Margin="2,0,0,0" ToolTip="Clear filter"
                            Click="ClearFilter_Click" />
                    <TextBox x:Name="FilterTextBox"
                             Text="{Binding ActiveTab.FileList.FilterText, UpdateSourceTrigger=PropertyChanged}"
                             VerticalContentAlignment="Center" Padding="4,2" />
                </DockPanel>

                <!-- Search Bar (Ctrl+E) -->
                <DockPanel x:Name="SearchBar" Grid.Row="1" Margin="2,2,2,0"
                           Visibility="{Binding ActiveTab.FileList.IsSearchVisible, Converter={StaticResource BoolToVisibility}, FallbackValue=Collapsed}">
                    <Image DockPanel.Dock="Left" Source="{StaticResource IconSearch}"
                           Width="14" Height="14" Margin="4,0,2,0" />
                    <TextBlock DockPanel.Dock="Left" Text="Search:" VerticalAlignment="Center"
                               Margin="2,0,4,0" />
                    <Button DockPanel.Dock="Right" Content="&#x2715;" FontSize="10"
                            Padding="4,1" Margin="2,0,0,0" ToolTip="Close search"
                            Command="{Binding ActiveTab.FileList.CloseSearchCommand}" />
                    <Button DockPanel.Dock="Right" Content="Go" Padding="6,1" Margin="2,0,0,0"
                            Command="{Binding ActiveTab.FileList.ExecuteSearchCommand}" />
                    <TextBox x:Name="SearchTextBox"
                             Text="{Binding ActiveTab.FileList.SearchText, UpdateSourceTrigger=PropertyChanged}"
                             VerticalContentAlignment="Center" Padding="4,2"
                             KeyDown="SearchTextBox_KeyDown" />
                </DockPanel>

                <!-- Search Results Banner -->
                <Border Grid.Row="2" Margin="2,2,2,0" Padding="4,2"
                        Background="#FFF8DC" BorderBrush="#DAA520" BorderThickness="1" CornerRadius="2"
                        Visibility="{Binding ActiveTab.FileList.IsShowingSearchResults, Converter={StaticResource BoolToVisibility}, FallbackValue=Collapsed}">
                    <DockPanel>
                        <Button DockPanel.Dock="Right" Content="&#x2715;" FontSize="10"
                                Padding="4,1" ToolTip="Clear search results"
                                Background="Transparent" BorderThickness="0"
                                Command="{Binding ActiveTab.FileList.ClearSearchResultsCommand}" />
                        <TextBlock Text="{Binding ActiveTab.FileList.SearchResultsText}"
                                   VerticalAlignment="Center" />
                    </DockPanel>
                </Border>

                <ListView x:Name="FileListView"
                          Grid.Row="3"
                          ItemsSource="{Binding ActiveTab.FileList.Items}"
                          SelectedItem="{Binding ActiveTab.FileList.SelectedItem}"
                          AllowDrop="True"
                          SelectionMode="Extended"
                          VirtualizingStackPanel.IsVirtualizing="True"
                          VirtualizingStackPanel.VirtualizationMode="Recycling"
                          SelectionChanged="FileList_SelectionChanged"
                          PreviewMouseLeftButtonDown="FileList_PreviewMouseLeftButtonDown"
                          MouseMove="FileList_MouseMove"
                          DragEnter="FileList_DragEnter"
                          DragOver="FileList_DragOver"
                          Drop="FileList_Drop"
                          MouseDoubleClick="FileList_MouseDoubleClick"
                          ContextMenuOpening="FileList_ContextMenuOpening"
                          GridViewColumnHeader.Click="FileListHeader_Click">
                    <ListView.ContextMenu>
                        <ContextMenu>
                            <MenuItem x:Name="OpenMenuItem" Header="Open" Command="{Binding ActiveTab.FileList.OpenItemCommand}" CommandParameter="{Binding ActiveTab.FileList.SelectedItem}" />
                            <Separator x:Name="ItemSeparator1" />
                            <MenuItem x:Name="CutMenuItem" Header="Cut" Command="{Binding ActiveTab.FileList.CutCommand}" />
                            <MenuItem x:Name="CopyMenuItem" Header="Copy" Command="{Binding ActiveTab.FileList.CopyCommand}" />
                            <MenuItem x:Name="PasteMenuItem" Header="Paste" Command="{Binding ActiveTab.FileList.PasteCommand}" />
                            <Separator x:Name="ItemSeparator2" />
                            <MenuItem x:Name="DeleteMenuItem" Header="Delete" Command="{Binding ActiveTab.FileList.DeleteCommand}" />
                            <MenuItem x:Name="RenameMenuItem" Header="Rename" Command="{Binding ActiveTab.FileList.RenameCommand}" />
                            <MenuItem x:Name="NewFolderMenuItem" Header="New Folder" Command="{Binding ActiveTab.FileList.NewFolderCommand}" />
                            <MenuItem x:Name="RefreshMenuItem" Header="Refresh" Command="{Binding ActiveTab.FileList.RefreshCommand}" />
                            <Separator x:Name="PropertiesSeparator" />
                            <MenuItem x:Name="OpenInExplorerMenuItem" Header="Open in Explorer" Click="OpenInExplorer_Click" />
                            <MenuItem x:Name="PropertiesMenuItem" Header="Properties" Command="{Binding ActiveTab.FileList.ShowPropertiesCommand}" />
                        </ContextMenu>
                    </ListView.ContextMenu>
                    <ListView.View>
                        <GridView>
                            <GridViewColumn Header="Name" Width="350"
                                            CellTemplate="{StaticResource DetailsNameCellTemplate}" />
                            <GridViewColumn Header="Size" Width="100"
                                            DisplayMemberBinding="{Binding DisplaySize}" />
                            <GridViewColumn Header="Type" Width="120"
                                            DisplayMemberBinding="{Binding TypeDescription}" />
                            <GridViewColumn Header="Date Modified" Width="160"
                                            DisplayMemberBinding="{Binding DateModified, StringFormat={}{0:yyyy-MM-dd HH:mm}}" />
                        </GridView>
                    </ListView.View>
                </ListView>

                <Popup x:Name="InlineRenamePopup"
                       Grid.Row="3"
                       PlacementTarget="{Binding ElementName=FileListView}"
                       Placement="Relative"
                       StaysOpen="False"
                       AllowsTransparency="True">
                    <Border BorderBrush="#999999" BorderThickness="1" Background="White" Padding="1">
                        <TextBox x:Name="InlineRenameTextBox"
                                 MinWidth="220"
                                 KeyDown="InlineRenameTextBox_KeyDown"
                                 LostKeyboardFocus="InlineRenameTextBox_LostKeyboardFocus" />
                    </Border>
                </Popup>
            </Grid>
        </Grid>
    </DockPanel>
</Window>
