<Window x:Class="CubicAIExplorer.PreferencesWindow"
        xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
        xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
        Title="Preferences" Width="760" Height="540"
        WindowStartupLocation="CenterOwner"
        ShowInTaskbar="False">
    <Grid Margin="16">
        <Grid.RowDefinitions>
            <RowDefinition Height="*" />
            <RowDefinition Height="Auto" />
        </Grid.RowDefinitions>

        <TabControl Grid.Row="0">
            <TabItem Header="General">
                <Grid Margin="12">
                    <Grid.RowDefinitions>
                        <RowDefinition Height="Auto" />
                        <RowDefinition Height="Auto" />
                        <RowDefinition Height="Auto" />
                        <RowDefinition Height="Auto" />
                        <RowDefinition Height="Auto" />
                        <RowDefinition Height="Auto" />
                        <RowDefinition Height="Auto" />
                        <RowDefinition Height="*" />
                    </Grid.RowDefinitions>
                    <Grid.ColumnDefinitions>
                        <ColumnDefinition Width="Auto" />
                        <ColumnDefinition Width="*" />
                    </Grid.ColumnDefinitions>

                    <TextBlock Grid.Row="0" Grid.Column="0" Text="Default view mode:"
                               VerticalAlignment="Center" Margin="0,0,12,8" />
                    <ComboBox x:Name="ViewModeCombo" Grid.Row="0" Grid.Column="1" Margin="0,0,0,8"
                              SelectedItem="{Binding DefaultViewMode}">
                        <ComboBoxItem Content="Details" IsSelected="True" />
                        <ComboBoxItem Content="List" />
                        <ComboBoxItem Content="Tiles" />
                    </ComboBox>

                    <CheckBox x:Name="ShowHiddenCheck" Grid.Row="1" Grid.Column="0" Grid.ColumnSpan="2"
                              Content="Show hidden files by default" Margin="0,0,0,8"
                              IsChecked="{Binding ShowHiddenFiles}" />

                    <CheckBox x:Name="DualPaneCheck" Grid.Row="2" Grid.Column="0" Grid.ColumnSpan="2"
                              Content="Start in dual-pane mode" Margin="0,0,0,8"
                              IsChecked="{Binding StartInDualPane}" />

                    <CheckBox x:Name="PreviewCheck" Grid.Row="3" Grid.Column="0" Grid.ColumnSpan="2"
                              Content="Start with preview panel open" Margin="0,0,0,8"
                              IsChecked="{Binding StartWithPreview}" />

                    <CheckBox x:Name="ShellContextMenuCheck" Grid.Row="4" Grid.Column="0" Grid.ColumnSpan="2"
                              Content="Use Windows Shell context menu" Margin="0,0,0,8"
                              IsChecked="{Binding UseShellContextMenu}" />

                    <TextBlock Grid.Row="5" Grid.Column="0" Text="Startup folder:"
                               VerticalAlignment="Center" Margin="0,0,12,8" />
                    <DockPanel Grid.Row="5" Grid.Column="1" Margin="0,0,0,8">
                        <Button DockPanel.Dock="Right" Content="Browse..." Padding="8,2"
                                Margin="4,0,0,0" Click="BrowseFolder_Click" />
                        <TextBox x:Name="StartupFolderBox" Text="{Binding StartupFolder, UpdateSourceTrigger=PropertyChanged}"
                                 VerticalContentAlignment="Center" Padding="4,2" />
                    </DockPanel>

                    <TextBlock Grid.Row="6" Grid.Column="0" Text="Template folder:"
                               VerticalAlignment="Center" Margin="0,0,12,8" />
                    <DockPanel Grid.Row="6" Grid.Column="1" Margin="0,0,0,8">
                        <Button DockPanel.Dock="Right" Content="Browse..." Padding="8,2"
                                Margin="4,0,0,0" Click="BrowseTemplatesFolder_Click" />
                        <TextBox x:Name="TemplatesFolderBox" Text="{Binding NewFileTemplatesPath, UpdateSourceTrigger=PropertyChanged}"
                                 VerticalContentAlignment="Center" Padding="4,2" />
                    </DockPanel>

                    <TextBlock Grid.Row="7" Grid.Column="0" Grid.ColumnSpan="2"
                               Text="Leave startup folder empty to use your user profile."
                               Foreground="Gray" FontSize="10" Margin="0,0,0,12" />
                </Grid>
            </TabItem>

            <TabItem Header="External Tools">
                <Grid Margin="12">
                    <Grid.RowDefinitions>
                        <RowDefinition Height="Auto" />
                        <RowDefinition Height="*" />
                        <RowDefinition Height="Auto" />
                    </Grid.RowDefinitions>

                    <TextBlock Grid.Row="0"
                               Text="Add external programs and use %p in arguments to insert the selected file path."
                               TextWrapping="Wrap"
                               Margin="0,0,0,10" />

                    <DataGrid x:Name="ExternalToolsGrid"
                              Grid.Row="1"
                              ItemsSource="{Binding ExternalTools}"
                              AutoGenerateColumns="False"
                              CanUserAddRows="False"
                              CanUserDeleteRows="False"
                              HeadersVisibility="Column"
                              SelectionMode="Single"
                              SelectionUnit="FullRow"
                              RowHeaderWidth="0"
                              Margin="0,0,0,10">
                        <DataGrid.Columns>
                            <DataGridTextColumn Header="Name"
                                                Binding="{Binding Name, UpdateSourceTrigger=PropertyChanged}"
                                                Width="180" />
                            <DataGridTextColumn Header="Program Path"
                                                Binding="{Binding ToolPath, UpdateSourceTrigger=PropertyChanged}"
                                                Width="*" />
                            <DataGridTextColumn Header="Arguments"
                                                Binding="{Binding Arguments, UpdateSourceTrigger=PropertyChanged}"
                                                Width="220" />
                        </DataGrid.Columns>
                    </DataGrid>

                    <StackPanel Grid.Row="2"
                                Orientation="Horizontal"
                                HorizontalAlignment="Right">
                        <Button Content="Add Tool" Width="90" Margin="0,0,8,0" Click="AddExternalTool_Click" />
                        <Button Content="Browse Program..." Width="120" Margin="0,0,8,0" Click="BrowseExternalTool_Click" />
                        <Button Content="Remove Tool" Width="100" Click="RemoveExternalTool_Click" />
                    </StackPanel>
                </Grid>
            </TabItem>
        </TabControl>

        <StackPanel Grid.Row="1"
                    Orientation="Horizontal"
                    HorizontalAlignment="Right"
                    Margin="0,12,0,0">
            <Button Content="OK" Width="80" Margin="0,0,8,0" IsDefault="True"
                    Click="OK_Click" />
            <Button Content="Cancel" Width="80" IsCancel="True"
                    Click="Cancel_Click" />
        </StackPanel>
    </Grid>
</Window>
