<Window x:Class="CubicAIExplorer.PreferencesWindow"
        xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
        xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
        Title="Preferences" Width="420" Height="340"
        WindowStartupLocation="CenterOwner"
        ResizeMode="NoResize"
        ShowInTaskbar="False">
    <Grid Margin="16">
        <Grid.RowDefinitions>
            <RowDefinition Height="Auto" />
            <RowDefinition Height="Auto" />
            <RowDefinition Height="Auto" />
            <RowDefinition Height="Auto" />
            <RowDefinition Height="Auto" />
            <RowDefinition Height="Auto" />
            <RowDefinition Height="*" />
            <RowDefinition Height="Auto" />
        </Grid.RowDefinitions>
        <Grid.ColumnDefinitions>
            <ColumnDefinition Width="Auto" />
            <ColumnDefinition Width="*" />
        </Grid.ColumnDefinitions>

        <!-- Default View Mode -->
        <TextBlock Grid.Row="0" Grid.Column="0" Text="Default view mode:"
                   VerticalAlignment="Center" Margin="0,0,12,8" />
        <ComboBox x:Name="ViewModeCombo" Grid.Row="0" Grid.Column="1" Margin="0,0,0,8"
                  SelectedItem="{Binding DefaultViewMode}">
            <ComboBoxItem Content="Details" IsSelected="True" />
            <ComboBoxItem Content="List" />
            <ComboBoxItem Content="Tiles" />
        </ComboBox>

        <!-- Show Hidden Files -->
        <CheckBox x:Name="ShowHiddenCheck" Grid.Row="1" Grid.Column="0" Grid.ColumnSpan="2"
                  Content="Show hidden files by default" Margin="0,0,0,8"
                  IsChecked="{Binding ShowHiddenFiles}" />

        <!-- Start in Dual Pane -->
        <CheckBox x:Name="DualPaneCheck" Grid.Row="2" Grid.Column="0" Grid.ColumnSpan="2"
                  Content="Start in dual-pane mode" Margin="0,0,0,8"
                  IsChecked="{Binding StartInDualPane}" />

        <!-- Start with Preview -->
        <CheckBox x:Name="PreviewCheck" Grid.Row="3" Grid.Column="0" Grid.ColumnSpan="2"
                  Content="Start with preview panel open" Margin="0,0,0,8"
                  IsChecked="{Binding StartWithPreview}" />

        <!-- Shell Context Menu -->
        <CheckBox x:Name="ShellContextMenuCheck" Grid.Row="4" Grid.Column="0" Grid.ColumnSpan="2"
                  Content="Use Windows Shell context menu" Margin="0,0,0,8"
                  IsChecked="{Binding UseShellContextMenu}" />

        <!-- Startup Folder -->
        <TextBlock Grid.Row="5" Grid.Column="0" Text="Startup folder:"
                   VerticalAlignment="Center" Margin="0,0,12,8" />
        <DockPanel Grid.Row="5" Grid.Column="1" Margin="0,0,0,8">
            <Button DockPanel.Dock="Right" Content="Browse..." Padding="8,2"
                    Margin="4,0,0,0" Click="BrowseFolder_Click" />
            <TextBox x:Name="StartupFolderBox" Text="{Binding StartupFolder, UpdateSourceTrigger=PropertyChanged}"
                     VerticalContentAlignment="Center" Padding="4,2" />
        </DockPanel>

        <TextBlock Grid.Row="6" Grid.Column="0" Grid.ColumnSpan="2"
                   Text="Leave startup folder empty to use your user profile."
                   Foreground="Gray" FontSize="10" Margin="0,0,0,12" />

        <!-- Buttons -->
        <StackPanel Grid.Row="7" Grid.Column="0" Grid.ColumnSpan="2"
                    Orientation="Horizontal" HorizontalAlignment="Right">
            <Button Content="OK" Width="80" Margin="0,0,8,0" IsDefault="True"
                    Click="OK_Click" />
            <Button Content="Cancel" Width="80" IsCancel="True"
                    Click="Cancel_Click" />
        </StackPanel>
    </Grid>
</Window>
