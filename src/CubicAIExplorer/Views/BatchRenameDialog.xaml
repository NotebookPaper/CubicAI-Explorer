<Window x:Class="CubicAIExplorer.Views.BatchRenameDialog"
        xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
        xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
        Title="Batch Rename"
        Width="760"
        Height="560"
        MinWidth="720"
        MinHeight="520"
        WindowStartupLocation="CenterOwner"
        ShowInTaskbar="False">
    <Grid Margin="12">
        <Grid.RowDefinitions>
            <RowDefinition Height="Auto" />
            <RowDefinition Height="Auto" />
            <RowDefinition Height="*" />
            <RowDefinition Height="Auto" />
        </Grid.RowDefinitions>

        <TextBlock Text="{Binding HeaderText}"
                   FontWeight="SemiBold"
                   Margin="0,0,0,12" />

        <Grid Grid.Row="1" Margin="0,0,0,12">
            <Grid.ColumnDefinitions>
                <ColumnDefinition Width="*" />
                <ColumnDefinition Width="*" />
            </Grid.ColumnDefinitions>
            <Grid.RowDefinitions>
                <RowDefinition Height="Auto" />
                <RowDefinition Height="Auto" />
                <RowDefinition Height="Auto" />
                <RowDefinition Height="Auto" />
            </Grid.RowDefinitions>

            <TextBlock Text="Find" Margin="0,0,0,4" />
            <TextBox x:Name="FindTextBox"
                     Grid.Row="1"
                     Margin="0,0,12,10"
                     TextChanged="OptionsChanged" />

            <TextBlock Grid.Column="1" Text="Replace" Margin="0,0,0,4" />
            <TextBox x:Name="ReplaceTextBox"
                     Grid.Column="1"
                     Grid.Row="1"
                     Margin="0,0,0,10"
                     TextChanged="OptionsChanged" />

            <TextBlock Grid.Row="2" Text="Case" Margin="0,0,0,4" />
            <ComboBox x:Name="CaseModeComboBox"
                      Grid.Row="3"
                      Margin="0,0,12,10"
                      SelectionChanged="OptionsChanged" />

            <TextBlock Grid.Column="1" Grid.Row="2" Text="Counter" Margin="0,0,0,4" />
            <StackPanel Grid.Column="1" Grid.Row="3" Orientation="Horizontal">
                <ComboBox x:Name="CounterPositionComboBox"
                          Width="120"
                          Margin="0,0,8,10"
                          SelectionChanged="OptionsChanged" />
                <TextBox x:Name="CounterStartTextBox"
                         Width="56"
                         Margin="0,0,8,10"
                         TextChanged="OptionsChanged" />
                <TextBox x:Name="CounterPaddingTextBox"
                         Width="56"
                         Margin="0,0,8,10"
                         TextChanged="OptionsChanged" />
                <TextBox x:Name="CounterSeparatorTextBox"
                         Width="72"
                         Margin="0,0,0,10"
                         TextChanged="OptionsChanged" />
            </StackPanel>
        </Grid>

        <Grid Grid.Row="2" Margin="0,0,0,12">
            <Grid.RowDefinitions>
                <RowDefinition Height="Auto" />
                <RowDefinition Height="*" />
            </Grid.RowDefinitions>

            <StackPanel Orientation="Horizontal" Margin="0,0,0,8">
                <TextBlock Text="Extension" VerticalAlignment="Center" Margin="0,0,8,0" />
                <ComboBox x:Name="ExtensionModeComboBox"
                          Width="120"
                          Margin="0,0,8,0"
                          SelectionChanged="OptionsChanged" />
                <TextBox x:Name="ExtensionTextBox"
                         Width="120"
                         TextChanged="OptionsChanged" />
            </StackPanel>

            <DataGrid x:Name="PreviewGrid"
                      Grid.Row="1"
                      AutoGenerateColumns="False"
                      IsReadOnly="True"
                      CanUserAddRows="False"
                      HeadersVisibility="Column"
                      ItemsSource="{Binding PreviewItems}">
                <DataGrid.Columns>
                    <DataGridTextColumn Header="Original Name" Binding="{Binding OriginalName}" Width="*" />
                    <DataGridTextColumn Header="New Name" Binding="{Binding NewName}" Width="*" />
                </DataGrid.Columns>
            </DataGrid>
        </Grid>

        <StackPanel Grid.Row="3"
                    Orientation="Horizontal"
                    HorizontalAlignment="Right">
            <Button Content="Rename"
                    Width="88"
                    Margin="0,0,8,0"
                    IsDefault="True"
                    Click="OnRenameClick" />
            <Button Content="Cancel"
                    Width="88"
                    IsCancel="True" />
        </StackPanel>
    </Grid>
</Window>
