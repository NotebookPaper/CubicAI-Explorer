<Window x:Class="CubicAIExplorer.Views.SplitFileDialog"
        xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
        xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
        Title="Split File" Width="520" Height="250"
        WindowStartupLocation="CenterOwner"
        ResizeMode="NoResize"
        ShowInTaskbar="False">
    <Grid Margin="16">
        <Grid.RowDefinitions>
            <RowDefinition Height="Auto" />
            <RowDefinition Height="Auto" />
            <RowDefinition Height="Auto" />
            <RowDefinition Height="*" />
            <RowDefinition Height="Auto" />
        </Grid.RowDefinitions>
        <Grid.ColumnDefinitions>
            <ColumnDefinition Width="110" />
            <ColumnDefinition Width="*" />
            <ColumnDefinition Width="Auto" />
        </Grid.ColumnDefinitions>

        <TextBlock Grid.Row="0" Grid.Column="0" Margin="0,4,8,4" VerticalAlignment="Center" Text="Source file:" />
        <TextBox Grid.Row="0" Grid.Column="1" x:Name="SourcePathTextBox" Margin="0,4,8,4" />
        <Button Grid.Row="0" Grid.Column="2" Content="Browse..." Padding="10,4" Click="BrowseSource_Click" />

        <TextBlock Grid.Row="1" Grid.Column="0" Margin="0,4,8,4" VerticalAlignment="Center" Text="Output folder:" />
        <TextBox Grid.Row="1" Grid.Column="1" Grid.ColumnSpan="2" x:Name="OutputDirectoryTextBox" Margin="0,4,0,4" />

        <TextBlock Grid.Row="2" Grid.Column="0" Margin="0,4,8,4" VerticalAlignment="Center" Text="Chunk size:" />
        <StackPanel Grid.Row="2" Grid.Column="1" Grid.ColumnSpan="2" Orientation="Horizontal" Margin="0,4,0,4">
            <ComboBox x:Name="ChunkSizeComboBox" Width="220" SelectionChanged="ChunkSizeComboBox_SelectionChanged" />
            <TextBox x:Name="CustomChunkSizeTextBox" Width="90" Margin="12,0,4,0" IsEnabled="False" />
            <TextBlock VerticalAlignment="Center" Text="MB" />
        </StackPanel>

        <Border Grid.Row="3" Grid.ColumnSpan="3" Margin="0,12,0,0" Padding="10" Background="#FFF6F6F6" BorderBrush="#FFD0D0D0" BorderThickness="1">
            <TextBlock TextWrapping="Wrap"
                       Text="Chunks will be created beside the source file name using numbered suffixes such as .001, .002, and so on." />
        </Border>

        <StackPanel Grid.Row="4" Grid.ColumnSpan="3" Orientation="Horizontal" HorizontalAlignment="Right" Margin="0,16,0,0">
            <Button Content="Split" Width="90" Margin="0,0,8,0" Padding="8,4" IsDefault="True" Click="Split_Click" />
            <Button Content="Cancel" Width="90" Padding="8,4" IsCancel="True" />
        </StackPanel>
    </Grid>
</Window>
