<Window x:Class="CubicAIExplorer.Views.ExtractArchiveDialog"
        xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
        xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
        Title="Extract Archive"
        Width="520"
        Height="210"
        WindowStartupLocation="CenterOwner"
        ResizeMode="NoResize"
        ShowInTaskbar="False">
    <Grid Margin="12">
        <Grid.RowDefinitions>
            <RowDefinition Height="Auto" />
            <RowDefinition Height="Auto" />
            <RowDefinition Height="Auto" />
            <RowDefinition Height="*" />
        </Grid.RowDefinitions>

        <TextBlock x:Name="PromptTextBlock" Margin="0,0,0,8" TextWrapping="Wrap" />
        <TextBlock Grid.Row="1" Text="Destination folder:" Margin="0,0,0,6" />
        <TextBox x:Name="DestinationTextBox"
                 Grid.Row="2"
                 MinWidth="460"
                 Margin="0,0,0,10" />

        <Grid Grid.Row="3">
            <Grid.RowDefinitions>
                <RowDefinition Height="Auto" />
                <RowDefinition Height="Auto" />
            </Grid.RowDefinitions>
            <CheckBox x:Name="OpenFolderCheckBox"
                      Content="Open destination folder when extraction finishes"
                      Margin="0,0,0,12" />
            <StackPanel Grid.Row="1"
                        Orientation="Horizontal"
                        HorizontalAlignment="Right">
                <Button Content="Extract"
                        Width="90"
                        Margin="0,0,8,0"
                        IsDefault="True"
                        Click="OnOkClick" />
                <Button Content="Cancel"
                        Width="90"
                        IsCancel="True" />
            </StackPanel>
        </Grid>
    </Grid>
</Window>
