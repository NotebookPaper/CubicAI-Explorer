<Window x:Class="CubicAIExplorer.Views.RothIraCalculatorDialog"
        xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
        xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
        Title="Roth IRA Retirement Calculator" Width="600" Height="520"
        WindowStartupLocation="CenterOwner"
        ShowInTaskbar="False"
        ResizeMode="NoResize">
    <Grid Margin="20">
        <Grid.RowDefinitions>
            <RowDefinition Height="Auto" />
            <RowDefinition Height="20" />
            <RowDefinition Height="Auto" />
            <RowDefinition Height="Auto" />
            <RowDefinition Height="Auto" />
            <RowDefinition Height="20" />
            <RowDefinition Height="Auto" />
            <RowDefinition Height="*" />
            <RowDefinition Height="Auto" />
        </Grid.RowDefinitions>

        <!-- Title -->
        <TextBlock Grid.Row="0" FontSize="20" FontWeight="Bold"
                   Text="Roth IRA Retirement Calculator"
                   HorizontalAlignment="Center" />

        <!-- Age of Child Slider -->
        <GroupBox Grid.Row="2" Header="Child's Current Age" Padding="12,8">
            <Grid>
                <Grid.ColumnDefinitions>
                    <ColumnDefinition Width="*" />
                    <ColumnDefinition Width="80" />
                </Grid.ColumnDefinitions>
                <Slider x:Name="AgeSlider" Minimum="0" Maximum="30" Value="5"
                        IsSnapToTickEnabled="True" TickFrequency="1"
                        TickPlacement="BottomRight"
                        ValueChanged="Slider_ValueChanged" />
                <TextBlock Grid.Column="1" VerticalAlignment="Center" HorizontalAlignment="Center"
                           FontSize="16" FontWeight="SemiBold">
                    <Run x:Name="AgeDisplay" Text="5" />
                    <Run Text=" yrs" />
                </TextBlock>
            </Grid>
        </GroupBox>

        <!-- Monthly Deposit Slider -->
        <GroupBox Grid.Row="3" Header="Monthly Deposit" Padding="12,8" Margin="0,8,0,0">
            <Grid>
                <Grid.ColumnDefinitions>
                    <ColumnDefinition Width="*" />
                    <ColumnDefinition Width="100" />
                </Grid.ColumnDefinitions>
                <Slider x:Name="MonthlyDepositSlider" Minimum="25" Maximum="1000" Value="100"
                        IsSnapToTickEnabled="True" TickFrequency="25"
                        TickPlacement="BottomRight"
                        ValueChanged="Slider_ValueChanged" />
                <TextBlock Grid.Column="1" VerticalAlignment="Center" HorizontalAlignment="Center"
                           FontSize="16" FontWeight="SemiBold">
                    <Run Text="$" /><Run x:Name="DepositDisplay" Text="100" />
                    <Run Text="/mo" />
                </TextBlock>
            </Grid>
        </GroupBox>

        <!-- Annual Return Slider -->
        <GroupBox Grid.Row="4" Header="Average Annual Return (%)" Padding="12,8" Margin="0,8,0,0">
            <Grid>
                <Grid.ColumnDefinitions>
                    <ColumnDefinition Width="*" />
                    <ColumnDefinition Width="80" />
                </Grid.ColumnDefinitions>
                <Slider x:Name="ReturnRateSlider" Minimum="1" Maximum="15" Value="8"
                        IsSnapToTickEnabled="True" TickFrequency="0.5"
                        TickPlacement="BottomRight"
                        ValueChanged="Slider_ValueChanged" />
                <TextBlock Grid.Column="1" VerticalAlignment="Center" HorizontalAlignment="Center"
                           FontSize="16" FontWeight="SemiBold">
                    <Run x:Name="ReturnRateDisplay" Text="8" /><Run Text="%" />
                </TextBlock>
            </Grid>
        </GroupBox>

        <!-- Results -->
        <Border Grid.Row="6" Background="#F0F4FF" BorderBrush="#B0C4DE" BorderThickness="1"
                CornerRadius="6" Padding="16">
            <StackPanel>
                <TextBlock FontSize="14" Margin="0,0,0,6">
                    <Run Text="Years until retirement (age 65): " />
                    <Run x:Name="YearsDisplay" Text="60" FontWeight="Bold" />
                </TextBlock>
                <TextBlock FontSize="14" Margin="0,0,0,6">
                    <Run Text="Total contributed: " />
                    <Run x:Name="TotalContributedDisplay" Text="$0" FontWeight="Bold" Foreground="#2E7D32" />
                </TextBlock>
                <TextBlock FontSize="14" Margin="0,0,0,6">
                    <Run Text="Interest earned: " />
                    <Run x:Name="InterestEarnedDisplay" Text="$0" FontWeight="Bold" Foreground="#1565C0" />
                </TextBlock>
                <Separator Margin="0,4" />
                <TextBlock FontSize="18" FontWeight="Bold" Margin="0,4,0,0">
                    <Run Text="Estimated value at 65: " />
                    <Run x:Name="FutureValueDisplay" Text="$0" Foreground="#1B5E20" />
                </TextBlock>
                <TextBlock FontSize="11" Foreground="Gray" Margin="0,8,0,0"
                           x:Name="DisclaimerText"
                           Text="Tax-free withdrawals in retirement (Roth IRA). Assumes consistent monthly contributions and compounding. Actual returns will vary." />
            </StackPanel>
        </Border>

        <!-- Close Button -->
        <StackPanel Grid.Row="8" Orientation="Horizontal" HorizontalAlignment="Right" Margin="0,16,0,0">
            <Button Content="Close" Width="90" Padding="8,4" IsDefault="True" IsCancel="True" />
        </StackPanel>
    </Grid>
</Window>
