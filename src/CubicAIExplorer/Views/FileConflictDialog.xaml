<Window x:Class="CubicAIExplorer.Views.FileConflictDialog"
        xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
        xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
        Title="Replace Existing Items?"
        Width="460"
        Height="190"
        WindowStartupLocation="CenterOwner"
        ResizeMode="NoResize"
        ShowInTaskbar="False">
    <Grid Margin="12">
        <Grid.RowDefinitions>
            <RowDefinition Height="Auto" />
            <RowDefinition Height="*" />
            <RowDefinition Height="Auto" />
        </Grid.RowDefinitions>

        <TextBlock Text="Some items already exist in the destination folder."
                   FontWeight="SemiBold"
                   Margin="0,0,0,8" />

        <TextBlock Grid.Row="1"
                   x:Name="DetailsTextBlock"
                   TextWrapping="Wrap"
                   Margin="0,0,0,12" />

        <StackPanel Grid.Row="2"
                    Orientation="Horizontal"
                    HorizontalAlignment="Right">
            <Button Content="Replace"
                    Width="88"
                    Margin="0,0,8,0"
                    IsDefault="True"
                    Click="OnReplaceClick" />
            <Button Content="Keep Both"
                    Width="88"
                    Margin="0,0,8,0"
                    Click="OnKeepBothClick" />
            <Button Content="Skip"
                    Width="88"
                    Margin="0,0,8,0"
                    Click="OnSkipClick" />
            <Button Content="Cancel"
                    Width="88"
                    IsCancel="True" />
        </StackPanel>
    </Grid>
</Window>
