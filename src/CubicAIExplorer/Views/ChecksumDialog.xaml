<Window x:Class="CubicAIExplorer.Views.ChecksumDialog"
        xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
        xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
        Title="Checksum Tool" Width="560" Height="360"
        WindowStartupLocation="CenterOwner"
        ShowInTaskbar="False">
    <Grid Margin="16">
        <Grid.RowDefinitions>
            <RowDefinition Height="Auto" />
            <RowDefinition Height="Auto" />
            <RowDefinition Height="Auto" />
            <RowDefinition Height="Auto" />
            <RowDefinition Height="Auto" />
            <RowDefinition Height="12" />
            <RowDefinition Height="Auto" />
            <RowDefinition Height="Auto" />
            <RowDefinition Height="*" />
            <RowDefinition Height="Auto" />
        </Grid.RowDefinitions>
        <Grid.ColumnDefinitions>
            <ColumnDefinition Width="90" />
            <ColumnDefinition Width="*" />
            <ColumnDefinition Width="Auto" />
        </Grid.ColumnDefinitions>

        <TextBlock Grid.Row="0" Grid.Column="0" Margin="0,4,8,4" VerticalAlignment="Center" Text="File:" />
        <TextBox Grid.Row="0" Grid.Column="1" x:Name="FilePathTextBox" Margin="0,4,8,4" />
        <Button Grid.Row="0" Grid.Column="2" Content="Browse..." Padding="10,4" Click="BrowseFile_Click" />

        <Button Grid.Row="1" Grid.Column="2" Content="Generate" Padding="10,4" Margin="0,4,0,4" Click="Generate_Click" />

        <TextBlock Grid.Row="2" Grid.Column="0" Margin="0,4,8,4" VerticalAlignment="Top" Text="MD5:" />
        <TextBox Grid.Row="2" Grid.Column="1" Grid.ColumnSpan="2" x:Name="Md5TextBox" Margin="0,4,0,4" IsReadOnly="True" TextWrapping="Wrap" />

        <TextBlock Grid.Row="3" Grid.Column="0" Margin="0,4,8,4" VerticalAlignment="Top" Text="SHA1:" />
        <TextBox Grid.Row="3" Grid.Column="1" Grid.ColumnSpan="2" x:Name="Sha1TextBox" Margin="0,4,0,4" IsReadOnly="True" TextWrapping="Wrap" />

        <TextBlock Grid.Row="4" Grid.Column="0" Margin="0,4,8,4" VerticalAlignment="Top" Text="SHA256:" />
        <TextBox Grid.Row="4" Grid.Column="1" Grid.ColumnSpan="2" x:Name="Sha256TextBox" Margin="0,4,0,4" IsReadOnly="True" TextWrapping="Wrap" />

        <Separator Grid.Row="5" Grid.ColumnSpan="3" />

        <TextBlock Grid.Row="6" Grid.Column="0" Margin="0,4,8,4" VerticalAlignment="Center" Text="Compare:" />
        <ComboBox Grid.Row="6" Grid.Column="1" x:Name="ComparisonAlgorithmComboBox" Width="120" HorizontalAlignment="Left" Margin="0,4,0,4" SelectionChanged="ComparisonInputChanged" />

        <TextBox Grid.Row="7" Grid.Column="1" Grid.ColumnSpan="2" x:Name="ComparisonTextBox" Margin="0,4,0,4" TextChanged="ComparisonInputChanged" />
        <TextBlock Grid.Row="8" Grid.ColumnSpan="3" x:Name="ComparisonResultTextBlock" Margin="0,8,0,0" TextWrapping="Wrap" />

        <StackPanel Grid.Row="9" Grid.ColumnSpan="3" Orientation="Horizontal" HorizontalAlignment="Right" Margin="0,16,0,0">
            <Button Content="Close" Width="90" Padding="8,4" IsDefault="True" IsCancel="True" />
        </StackPanel>
    </Grid>
</Window>
