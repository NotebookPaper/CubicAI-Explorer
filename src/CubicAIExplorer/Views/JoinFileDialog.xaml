<Window x:Class="CubicAIExplorer.Views.JoinFileDialog"
        xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
        xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
        Title="Join File" Width="540" Height="215"
        WindowStartupLocation="CenterOwner"
        ResizeMode="NoResize"
        ShowInTaskbar="False">
    <Grid Margin="16">
        <Grid.RowDefinitions>
            <RowDefinition Height="Auto" />
            <RowDefinition Height="Auto" />
            <RowDefinition Height="*" />
            <RowDefinition Height="Auto" />
        </Grid.RowDefinitions>
        <Grid.ColumnDefinitions>
            <ColumnDefinition Width="120" />
            <ColumnDefinition Width="*" />
            <ColumnDefinition Width="Auto" />
        </Grid.ColumnDefinitions>

        <TextBlock Grid.Row="0" Grid.Column="0" Margin="0,4,8,4" VerticalAlignment="Center" Text="First chunk:" />
        <TextBox Grid.Row="0" Grid.Column="1" x:Name="FirstChunkPathTextBox" Margin="0,4,8,4" />
        <Button Grid.Row="0" Grid.Column="2" Content="Browse..." Padding="10,4" Click="BrowseFirstChunk_Click" />

        <TextBlock Grid.Row="1" Grid.Column="0" Margin="0,4,8,4" VerticalAlignment="Center" Text="Output file:" />
        <TextBox Grid.Row="1" Grid.Column="1" x:Name="OutputPathTextBox" Margin="0,4,8,4" />
        <Button Grid.Row="1" Grid.Column="2" Content="Browse..." Padding="10,4" Click="BrowseOutput_Click" />

        <Border Grid.Row="2" Grid.ColumnSpan="3" Margin="0,12,0,0" Padding="10" Background="#FFF6F6F6" BorderBrush="#FFD0D0D0" BorderThickness="1">
            <TextBlock TextWrapping="Wrap"
                       Text="Choose the first numbered chunk, typically the .001 file. The output file will be rebuilt from the full contiguous sequence." />
        </Border>

        <StackPanel Grid.Row="3" Grid.ColumnSpan="3" Orientation="Horizontal" HorizontalAlignment="Right" Margin="0,16,0,0">
            <Button Content="Join" Width="90" Margin="0,0,8,0" Padding="8,4" IsDefault="True" Click="Join_Click" />
            <Button Content="Cancel" Width="90" Padding="8,4" IsCancel="True" />
        </StackPanel>
    </Grid>
</Window>
