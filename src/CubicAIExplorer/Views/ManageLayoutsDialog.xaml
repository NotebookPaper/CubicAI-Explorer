<Window x:Class="CubicAIExplorer.Views.ManageLayoutsDialog"
        xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
        xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
        xmlns:models="clr-namespace:CubicAIExplorer.Models"
        Title="Manage Layouts"
        Width="460"
        Height="320"
        WindowStartupLocation="CenterOwner"
        ResizeMode="CanMinimize"
        ShowInTaskbar="False">
    <Grid Margin="12">
        <Grid.RowDefinitions>
            <RowDefinition Height="Auto" />
            <RowDefinition Height="*" />
            <RowDefinition Height="Auto" />
        </Grid.RowDefinitions>

        <TextBlock Text="Saved window layouts"
                   FontWeight="SemiBold"
                   Margin="0,0,0,8" />

        <ListBox x:Name="LayoutsListBox"
                 Grid.Row="1"
                 DisplayMemberPath="Name"
                 MouseDoubleClick="LayoutsListBox_MouseDoubleClick"
                 MinHeight="180" />

        <DockPanel Grid.Row="2" Margin="0,12,0,0">
            <TextBlock x:Name="EmptyStateText"
                       Text="No saved layouts."
                       VerticalAlignment="Center"
                       Foreground="#5A6F89"
                       Visibility="Collapsed" />
            <StackPanel DockPanel.Dock="Right"
                        Orientation="Horizontal">
                <Button x:Name="ApplyButton"
                        Content="Apply"
                        Width="82"
                        Margin="0,0,8,0"
                        Click="ApplyButton_Click" />
                <Button x:Name="DeleteButton"
                        Content="Delete"
                        Width="82"
                        Margin="0,0,8,0"
                        Click="DeleteButton_Click" />
                <Button Content="Close"
                        Width="82"
                        IsDefault="True"
                        IsCancel="True" />
            </StackPanel>
        </DockPanel>
    </Grid>
</Window>
